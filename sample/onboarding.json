  "spec": {
    "schemaVersion": "2.0",
    "description": "Four-phase transformation of employee onboarding: Phase 0 (Paper HR) uses paper packets, manual IT requests, and walk-around introductions. Phase 1 (Digital Forms) moves to online HR forms and email-based IT provisioning. Phase 2 (Auto Provisioning) introduces auto-created accounts, checklist tracking, and digital training. Phase 3 (AI Onboarding) deploys an AI onboarding agent with personalized learning paths and proactive IT setup.",
    "nodeInventory": [
      { "id": "start",            "type": "start-event",        "lane": "hr",       "role": "Hire confirmed — triggers the onboarding workflow in every phase", "critical": true },
      { "id": "paper-packet",     "type": "task",               "lane": "hr",       "phase": ["phase0"], "role": "HR prints and assembles paper onboarding packet for new hire", "critical": true },
      { "id": "fill-paper",       "type": "task",               "lane": "employee", "phase": ["phase0"], "role": "Employee fills out paper forms by hand — primary error source", "critical": true },
      { "id": "collect-docs",     "type": "task",               "lane": "hr",       "phase": ["phase0"], "role": "HR collects, reviews, and files physical documents", "critical": true },
      { "id": "manual-it-req",    "type": "task",               "lane": "hr",       "phase": ["phase0"], "role": "HR emails IT department with manual setup request", "critical": true },
      { "id": "manual-provision", "type": "task",               "lane": "it",       "phase": ["phase0"], "role": "IT manually creates accounts, configures hardware and access", "critical": true },
      { "id": "walk-intro",       "type": "task",               "lane": "employee", "phase": ["phase0"], "role": "Employee walks around office for in-person introductions", "critical": false },
      { "id": "online-forms",     "type": "task",               "lane": "employee", "phase": ["phase1"], "role": "Employee completes digitized HR forms online", "critical": true },
      { "id": "hr-review",        "type": "task",               "lane": "hr",       "phase": ["phase1"], "role": "HR reviews digital submission for completeness", "critical": true },
      { "id": "email-it-prov",    "type": "task",               "lane": "hr",       "phase": ["phase1"], "role": "HR sends email-based IT provisioning request", "critical": true },
      { "id": "manual-setup",     "type": "task",               "lane": "it",       "phase": ["phase1"], "role": "IT manually processes provisioning from email request", "critical": true },
      { "id": "email-welcome",    "type": "task",               "lane": "hr",       "phase": ["phase1"], "role": "HR sends digital welcome pack via email", "critical": false },
      { "id": "portal-submit",    "type": "task",               "lane": "employee", "phase": "phase2",   "role": "Employee uses self-service portal for all onboarding data and documents", "critical": true },
      { "id": "auto-verify",      "type": "subprocess",         "lane": "system",   "phase": "phase2",   "role": "System auto-verifies uploaded documents against HR rules", "critical": true },
      { "id": "auto-provision",   "type": "subprocess",         "lane": "system",   "phase": ["phase2"], "role": "System auto-creates AD accounts, email, and app access", "critical": true },
      { "id": "checklist-track",  "type": "task",               "lane": "hr",       "phase": ["phase2"], "role": "Digital checklist tracks onboarding task completion", "critical": true },
      { "id": "digital-training", "type": "task",               "lane": "employee", "phase": ["phase2"], "role": "Employee completes assigned digital training modules", "critical": true },
      { "id": "notify-employee",  "type": "intermediate-event", "lane": "system",   "phase": "phase2",   "role": "System notifies employee that all setup is complete", "critical": false },
      { "id": "ai-agent",         "type": "agent",              "lane": "system",   "phase": "phase3",   "role": "AI onboarding agent orchestrates entire process end-to-end", "critical": true },
      { "id": "proactive-it",     "type": "subprocess",         "lane": "system",   "phase": "phase3",   "role": "AI triggers proactive IT setup before employee's start date", "critical": true },
      { "id": "personal-path",    "type": "subprocess",         "lane": "system",   "phase": "phase3",   "role": "AI generates personalized learning path based on role and skills", "critical": true },
      { "id": "smart-intro",      "type": "task",               "lane": "employee", "phase": "phase3",   "role": "AI schedules smart team introductions based on org graph", "critical": false },
      { "id": "gateway-ready",    "type": "gateway",            "lane": "hr",                            "role": "Readiness gate — verifies all onboarding tasks are complete", "critical": true },
      { "id": "end",              "type": "end-event",          "lane": "employee",                      "role": "Employee fully onboarded and Day 1 ready", "critical": false }
    ],
    "connectionInventory": [
      { "id": "c-start-paper",        "from": "start",            "to": "paper-packet",     "semantics": "HR prints paper packet on hire confirmation" },
      { "id": "c-paper-fill",         "from": "paper-packet",     "to": "fill-paper",       "semantics": "Paper packet handed to new employee for completion" },
      { "id": "c-fill-collect",       "from": "fill-paper",       "to": "collect-docs",     "semantics": "Completed paper forms returned to HR for filing" },
      { "id": "c-collect-itreq",      "from": "collect-docs",     "to": "manual-it-req",    "semantics": "HR validates docs then emails IT access request" },
      { "id": "c-itreq-prov",         "from": "manual-it-req",    "to": "manual-provision",  "semantics": "IT receives email request and begins manual provisioning" },
      { "id": "c-prov-intro",         "from": "manual-provision", "to": "walk-intro",        "semantics": "IT notifies employee that access is ready; walk-around begins" },
      { "id": "c-intro-gw",           "from": "walk-intro",       "to": "gateway-ready",     "semantics": "Introductions done; readiness check" },
      { "id": "c-start-online",       "from": "start",            "to": "online-forms",      "semantics": "HR sends digital form link to new employee" },
      { "id": "c-online-review",      "from": "online-forms",     "to": "hr-review",         "semantics": "Completed digital forms submitted to HR for review" },
      { "id": "c-review-emailit",     "from": "hr-review",        "to": "email-it-prov",     "semantics": "HR approves submission and emails IT provisioning request" },
      { "id": "c-emailit-setup",      "from": "email-it-prov",    "to": "manual-setup",      "semantics": "IT receives email and begins manual account setup" },
      { "id": "c-setup-welcome",      "from": "manual-setup",     "to": "email-welcome",     "semantics": "IT setup complete; HR sends welcome email pack" },
      { "id": "c-welcome-gw",         "from": "email-welcome",    "to": "gateway-ready",     "semantics": "Welcome sent; readiness check" },
      { "id": "c-start-portal",       "from": "start",            "to": "portal-submit",     "semantics": "HR triggers self-service portal invitation for employee" },
      { "id": "c-portal-verify",      "from": "portal-submit",    "to": "auto-verify",       "semantics": "Portal submission auto-sent to verification system" },
      { "id": "c-verify-autoprov",    "from": "auto-verify",      "to": "auto-provision",    "semantics": "Verified docs trigger automatic account provisioning" },
      { "id": "c-autoprov-checklist", "from": "auto-provision",   "to": "checklist-track",   "semantics": "Provisioning complete; checklist tracker updated" },
      { "id": "c-checklist-training", "from": "checklist-track",  "to": "digital-training",  "semantics": "Checklist assigns digital training modules to employee" },
      { "id": "c-training-notify",    "from": "digital-training", "to": "notify-employee",   "semantics": "Training complete; system sends readiness notification" },
      { "id": "c-notify-gw",          "from": "notify-employee",  "to": "gateway-ready",     "semantics": "Notification sent; readiness gate check" },
      { "id": "c-start-ai",           "from": "start",            "to": "ai-agent",          "semantics": "Hire confirmed; AI onboarding agent activated immediately" },
      { "id": "c-ai-proactive",       "from": "ai-agent",         "to": "proactive-it",      "semantics": "AI agent triggers proactive IT setup before Day 1" },
      { "id": "c-proactive-path",     "from": "proactive-it",     "to": "personal-path",     "semantics": "IT ready; AI generates personalized learning path" },
      { "id": "c-path-intro",         "from": "personal-path",    "to": "smart-intro",       "semantics": "Learning path assigned; AI schedules smart introductions" },
      { "id": "c-smartintro-gw",      "from": "smart-intro",      "to": "gateway-ready",     "semantics": "All AI-orchestrated steps complete; readiness gate" },
      { "id": "c-gw-end-yes",         "from": "gateway-ready",    "to": "end",               "semantics": "All checks passed; employee is fully onboarded" }
    ],
    "behaviors": [
      {
        "id": "beh-phase-slider",
        "trigger": "User moves phase slider from 0 to 3",
        "expectedOutcome": "Graph transitions through four distinct process topologies; nodes appear and disappear per phase visibility rules",
        "involvedNodes": ["start", "gateway-ready", "end"],
        "testRef": "J1-S1"
      },
      {
        "id": "beh-diff-highlight",
        "trigger": "User enables diff mode at Phase 2",
        "expectedOutcome": "Phase 1 nodes shown as removed (faded), Phase 2 nodes shown as added (green highlight)",
        "involvedNodes": ["portal-submit", "auto-verify", "online-forms", "hr-review"],
        "testRef": "J1-S2"
      },
      {
        "id": "beh-simulation-p3",
        "trigger": "User clicks Simulate at Phase 3",
        "expectedOutcome": "Token travels from start through ai-agent, proactive-it, personal-path, smart-intro, gateway-ready, end",
        "involvedNodes": ["start", "ai-agent", "proactive-it", "personal-path", "smart-intro", "gateway-ready", "end"],
        "testRef": "J5-S1"
      }
    ],
    "invariants": [
      "Every phase has exactly one path from start to end through gateway-ready",
      "No two nodes within the same lane share the same x coordinate at any single phase",
      "The start node, gateway-ready node, and end node are visible in all four phases",
      "Phase 3 contains no manual-state tasks — all tasks are automated or agent-driven",
      "All x coordinates fall within the range 100-1200"
    ]
  }
}
