  "notes": "Process Owner: HR Operations\nLast Reviewed: 2026-Q1\nSLA Target: Day 1 ready\nPhases: Paper HR -> Digital Forms -> Auto Provisioning -> AI Onboarding",

  "metrics": {
    "phase0": {
      "stepCount": 8,
