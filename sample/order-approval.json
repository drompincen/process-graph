  "story": {
    "storyId": "purchase-approval-transformation",
    "version": 2,
    "createdAt": "2026-01-15",
    "createdBy": "process.owner@company.com",
    "problem": {
      "headline": "Purchase approvals take 48 hours and have a 15% error rate",
      "description": "Finance manually checks every request against <b>budget spreadsheets</b>. Five handoffs per request create bottlenecks and delays. Paper forms get lost, phone notifications are unreliable, and there is no audit trail for rejected requests.",
      "impactMetric": {
        "kpiId": "cycle-time",
        "value": 48,
        "unit": "hours"
      },
      "evidence": [
        {
          "label": "Q3 Process Audit",
          "url": "#",
          "addedAt": "2026-01-10",
          "addedBy": "jane@co.com"
        },
        {
          "label": "Employee Survey (n=84)",
          "url": "#",
          "addedAt": "2026-01-12",
          "addedBy": "bob@co.com"
        }
      ],
      "scope": ["paper-form", "walk-to-manager", "finance-manual-check", "manager-review"],
      "risks": [
        "Manual checks miss mid-year policy changes",
        "No audit trail for rejected requests",
        "Finance team bottleneck — 2-3 day SLA breach",
        "Paper forms lost in transit"
      ]
    },
    "vision": {
      "summary": "AI-powered approval reduces cycle time to under 30 minutes with 92% automation",
      "description": "Replace paper forms with a <b>self-service portal</b>, add automated budget validation, then deploy an <b>AI smart routing agent</b> with anomaly detection and confidence-based auto-approval.",
      "kpiTargets": [
        {
          "kpiId": "cycle-time",
          "min": 0.25,
          "max": 0.5,
          "confidence": "high",
          "horizon": "Q4 2026"
        },
        {
          "kpiId": "error-rate",
          "min": 0.5,
          "max": 1,
          "confidence": "medium",
          "horizon": "Q4 2026"
        },
        {
          "kpiId": "handoffs",
          "min": 0,
          "max": 1,
          "confidence": "high",
          "horizon": "Q4 2026"
        }
      ],
      "acceptanceCriteria": [
        "Portal handles 100% of standard requests",
        "Auto budget check responds in under 3 seconds",
        "AI agent classifies requests in under 200ms",
        "Full digital audit trail maintained for all decisions",
        "Zero paper forms in process",
        "85% of requests auto-approved without human intervention"
      ]
    },
    "phases": [
      {
        "label": "Phase 0: Paper Baseline",
        "phaseRef": "phase0",
        "description": "All approvals use <b>paper forms</b>. Requester walks the form to the manager for a physical signature, then Finance manually checks the budget against spreadsheets. Notifications happen via phone calls. Average cycle time: 48 hours.",
        "duration": "current state"
      },
      {
        "label": "Phase 1: Digital Forms",
        "phaseRef": "phase1",
        "description": "Replace paper form with an <b>online portal</b>. Requests are emailed to the manager automatically. Manager still reviews everything manually. Email notifications replace phone calls.",
        "duration": "4 weeks"
      },
      {
        "label": "Phase 2: Auto Validation",
        "phaseRef": "phase2",
        "description": "Add <b>real-time API validation</b> against the Finance budget system. Requests under $5,000 are auto-approved. Only higher-value requests go to the manager. Finance team freed from routine manual checks.",
        "duration": "6 weeks"
      },
      {
        "label": "Phase 3: AI-Powered",
        "phaseRef": "phase3",
        "description": "Deploy an <b>AI smart routing agent</b> with anomaly detection and confidence scoring. 85% of requests are auto-approved. Manager only reviews flagged anomalies. Sub-minute approval times.",
        "duration": "4 weeks"
      }
    ],
    "ideaCards": [
      {
        "id": "ic1",
        "title": "Self-Service Portal",
        "phases": ["phase1"],
        "hypothesis": "Moving to a <b>structured web form</b> eliminates transcription errors, removes the paper handoff step, and enables email-based routing.",
        "expectedKpiImpacts": [
          { "kpiId": "handoffs", "delta": -1, "confidence": "high" },
          { "kpiId": "error-rate", "delta": -5, "confidence": "medium" },
          { "kpiId": "cycle-time", "delta": -24, "confidence": "medium" }
        ]
      },
      {
        "id": "ic2",
        "title": "Auto Budget Validation",
        "phases": ["phase2"],
        "hypothesis": "Real-time API call to Finance system replaces manual spreadsheet check — <b>removes Finance lane entirely</b> and auto-approves 60% of requests under $5k.",
        "expectedKpiImpacts": [
          { "kpiId": "cycle-time", "delta": -20, "confidence": "high" },
          { "kpiId": "handoffs", "delta": -2, "confidence": "high" },
          { "kpiId": "error-rate", "delta": -6, "confidence": "high" }
        ]
      },
