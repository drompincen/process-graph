  "spec": {
    "schemaVersion": "2.0",
    "description": "Four-phase progressive transformation of a purchase approval process: from paper-based manual (Phase 0) through digital forms (Phase 1), automated budget validation (Phase 2), to AI-powered smart routing with anomaly detection (Phase 3).",
    "nodeInventory": [
      {
        "id": "start",
        "type": "start-event",
        "lane": "requester",
        "role": "Triggers the approval process in all phases",
        "critical": true
      },
      {
        "id": "paper-form",
        "type": "task",
        "lane": "requester",
        "phase": ["phase0"],
        "role": "Employee manually fills a paper purchase request form — primary source of errors and delays",
        "critical": true
      },
      {
        "id": "walk-to-manager",
        "type": "task",
        "lane": "requester",
        "phase": ["phase0"],
        "role": "Employee physically walks the paper form to the manager's desk for signature",
        "critical": true
      },
      {
        "id": "manager-sign",
        "type": "task",
        "lane": "manager",
        "phase": ["phase0"],
        "role": "Manager reviews and physically signs the paper form",
        "critical": true
      },
      {
        "id": "finance-manual-check",
        "type": "task",
        "lane": "finance",
        "phase": ["phase0"],
        "role": "Finance team manually checks budget availability against spreadsheets — 2-3 day turnaround",
        "critical": true
      },
      {
        "id": "phone-notify",
        "type": "task",
        "lane": "requester",
        "phase": ["phase0"],
        "role": "Requester is notified of the decision via phone call — unreliable and undocumented",
        "critical": false
      },
      {
        "id": "bottleneck-note",
        "type": "annotation",
        "lane": "manager",
        "phase": ["phase0"],
        "role": "Documents the 2-3 day bottleneck at each manual handoff point",
        "critical": false
      },
      {
        "id": "portal-submit",
        "type": "task",
        "lane": "requester",
        "phase": "phase1",
        "role": "Employee submits a structured purchase request via the online portal — replaces paper form",
        "critical": true
      },
      {
        "id": "email-to-manager",
        "type": "task",
        "lane": "system",
        "phase": ["phase1"],
        "role": "System automatically emails the request to the appropriate manager — replaces physical form delivery",
        "critical": true
      },
      {
        "id": "manager-review",
        "type": "task",
        "lane": "manager",
        "phase": ["phase0", "phase1"],
        "role": "Manager manually reviews the request and makes approval decision",
        "critical": true
      },
      {
        "id": "email-notify",
        "type": "intermediate-event",
        "lane": "system",
        "phase": ["phase1"],
        "role": "System sends email notification to the requester about the decision outcome",
        "critical": false
      },
      {
        "id": "digital-note",
        "type": "annotation",
        "lane": "requester",
        "phase": ["phase1"],
        "role": "Documents that the portal eliminates paper forms but manual routing to manager remains",
        "critical": false
      },
      {
        "id": "auto-budget-check",
        "type": "subprocess",
        "lane": "system",
        "phase": ["phase2"],
        "role": "Automated real-time budget validation via Finance API — replaces manual Finance check; replaced by AI agent in Phase 3",
        "critical": true
      },
      {
        "id": "amount-gateway",
        "type": "gateway",
        "lane": "system",
        "phase": ["phase2"],
        "role": "Routes requests based on amount: under $5k auto-approved, over $5k escalated to manager",
        "critical": true
      },
      {
        "id": "manager-review-escalated",
        "type": "task",
        "lane": "manager",
        "phase": ["phase2"],
        "role": "Manager reviews only escalated requests exceeding the $5k threshold",
        "critical": true
      },
      {
        "id": "auto-approve-small",
        "type": "task",
        "lane": "system",
        "phase": ["phase2"],
        "role": "System auto-approves requests under $5k after budget validation passes",
        "critical": true
      },
      {
        "id": "system-notify",
        "type": "intermediate-event",
        "lane": "system",
        "phase": ["phase2"],
        "role": "System notification confirming auto-approval or escalation status",
        "critical": false
      },
      {
        "id": "budget-api",
        "type": "system",
        "lane": "finance",
        "phase": ["phase2"],
        "role": "Budget Validation API backing the automated check — connects to Finance ERP",
        "critical": true
      },
      {
        "id": "validation-note",
        "type": "annotation",
        "lane": "finance",
        "phase": ["phase2"],
        "role": "Documents that 60% of requests are auto-approved, freeing Finance from manual work",
        "critical": false
      },
      {
        "id": "smart-routing-agent",
        "type": "agent",
        "lane": "system",
        "phase": "phase3",
        "role": "AI agent that classifies requests, detects patterns, and determines routing strategy",
        "critical": true
      },
      {
        "id": "anomaly-detection",
        "type": "subprocess",
        "lane": "system",
        "phase": "phase3",
        "role": "ML-powered anomaly detection scanning for unusual vendor patterns, amounts, or frequency",
        "critical": true
      },
      {
        "id": "confidence-gateway",
        "type": "gateway",
        "lane": "system",
        "phase": "phase3",
        "role": "Routes based on AI confidence score: above 95% auto-approved, below 95% escalated",
        "critical": true
      },
      {
        "id": "ai-auto-approve",
        "type": "task",
        "lane": "system",
        "phase": "phase3",
        "role": "AI auto-approves high-confidence requests with full audit trail and confidence score logged",
        "critical": true
      },
      {
        "id": "manager-exception-review",
        "type": "task",
        "lane": "manager",
        "phase": "phase3",
        "role": "Manager reviews only AI-flagged anomalies and low-confidence exceptions",
        "critical": true
      },
      {
        "id": "ai-notify",
        "type": "intermediate-event",
        "lane": "system",
        "phase": "phase3",
        "role": "Smart notification with decision explanation, confidence score, and next steps",
        "critical": false
      },
      {
        "id": "ai-note",
        "type": "annotation",
        "lane": "manager",
        "phase": ["phase3"],
        "role": "Documents that 85% of requests are auto-approved by AI; manager reviews only anomalies",
        "critical": false
      },
      {
        "id": "approval-gateway",
        "type": "gateway",
        "lane": "manager",
        "phase": ["phase0", "phase1"],
        "role": "Manual approval decision split used in Phases 0 and 1: yes leads to approved, no leads to rejected",
        "critical": true
      },
      {
        "id": "approved",
        "type": "end-event",
        "lane": "requester",
        "role": "Request approved — requester notified of successful approval in all phases",
        "critical": true
      },
      {
        "id": "rejected",
        "type": "end-event",
        "lane": "requester",
        "role": "Request rejected — requester notified with reason code (digital audit trail from Phase 1 onward)",
        "critical": true
      },
      {
        "id": "employee-persona",
        "type": "persona",
        "lane": "requester",
        "phase": "phase1",
        "role": "Employee requester persona representing the end user of the portal",
        "critical": false
      }
    ],
    "connectionInventory": [
      { "id": "c-start-paper", "from": "start", "to": "paper-form", "semantics": "Process starts: employee picks up paper form" },
      { "id": "c-paper-walk", "from": "paper-form", "to": "walk-to-manager", "semantics": "Completed paper form carried to manager's office" },
      { "id": "c-walk-sign", "from": "walk-to-manager", "to": "manager-sign", "semantics": "Form handed to manager for physical signature (cross-lane)" },
      { "id": "c-sign-fincheck", "from": "manager-sign", "to": "finance-manual-check", "semantics": "Signed form sent to Finance for budget check (cross-lane)" },
      { "id": "c-fincheck-review", "from": "finance-manual-check", "to": "manager-review", "semantics": "Finance returns budget check result to manager (2-3 day delay)" },
      { "id": "c-review-gateway0", "from": "manager-review", "to": "approval-gateway", "semantics": "Manager decision forwarded to approval gateway" },
      { "id": "c-gateway0-approved", "from": "approval-gateway", "to": "approved", "semantics": "Approval granted", "conditions": "Budget available and policy satisfied" },
      { "id": "c-gateway0-rejected", "from": "approval-gateway", "to": "rejected", "semantics": "Approval denied", "conditions": "Budget exceeded or policy violation" },
      { "id": "c-approved-phone", "from": "approved", "to": "phone-notify", "semantics": "Requester notified of approval via phone call (no documentation)" },
      { "id": "c-review-loop", "from": "manager-review", "to": "manager-review", "semantics": "Manager requests more information from requester (self-loop)", "conditions": "Form incomplete or ambiguous" },
      { "id": "c-start-portal", "from": "start", "to": "portal-submit", "semantics": "Employee opens portal and begins structured submission" },
      { "id": "c-portal-email", "from": "portal-submit", "to": "email-to-manager", "semantics": "Structured request automatically emailed to manager" },
      { "id": "c-email-review", "from": "email-to-manager", "to": "manager-review", "semantics": "Manager receives email with request details for review" },
      { "id": "c-review-gateway1", "from": "manager-review", "to": "approval-gateway", "semantics": "Manager decision forwarded to approval gateway (Phase 1)" },
      { "id": "c-gateway1-email-notify", "from": "approval-gateway", "to": "email-notify", "semantics": "System sends email notification of decision to requester" },
      { "id": "c-persona-portal", "from": "employee-persona", "to": "portal-submit", "semantics": "Employee requester persona uses the portal (association)" },
      { "id": "c-portal-autobudget", "from": "portal-submit", "to": "auto-budget-check", "semantics": "Portal submission triggers automated budget validation" },
      { "id": "c-autobudget-amtgateway", "from": "auto-budget-check", "to": "amount-gateway", "semantics": "Budget validation result routes to amount-based decision gateway" },
      { "id": "c-amtgateway-escalate", "from": "amount-gateway", "to": "manager-review-escalated", "semantics": "High-value requests escalated to manager for review", "conditions": "Amount exceeds $5,000 threshold" },
      { "id": "c-amtgateway-auto", "from": "amount-gateway", "to": "auto-approve-small", "semantics": "Low-value requests auto-approved by system", "conditions": "Amount under $5,000 and budget available" },
      { "id": "c-escalated-approved", "from": "manager-review-escalated", "to": "approved", "semantics": "Manager approves escalated request" },
      { "id": "c-escalated-rejected", "from": "manager-review-escalated", "to": "rejected", "semantics": "Manager rejects escalated request" },
      { "id": "c-autosmall-approved", "from": "auto-approve-small", "to": "approved", "semantics": "Auto-approved request completes successfully" },
      { "id": "c-autosmall-notify", "from": "auto-approve-small", "to": "system-notify", "semantics": "System sends auto-approval notification to requester" },
      { "id": "c-autobudget-api", "from": "auto-budget-check", "to": "budget-api", "semantics": "Budget check subprocess calls the Finance ERP validation API" },
      { "id": "c-portal-smartagent", "from": "portal-submit", "to": "smart-routing-agent", "semantics": "Portal submission sent to AI smart routing agent for classification" },
      { "id": "c-smartagent-anomaly", "from": "smart-routing-agent", "to": "anomaly-detection", "semantics": "AI agent triggers anomaly detection scan on the request" },
      { "id": "c-anomaly-confidence", "from": "anomaly-detection", "to": "confidence-gateway", "semantics": "Anomaly detection produces confidence score for routing decision" },
      { "id": "c-confidence-autoapprove", "from": "confidence-gateway", "to": "ai-auto-approve", "semantics": "High-confidence requests auto-approved by AI", "conditions": "Confidence score above 95%" },
      { "id": "c-confidence-exception", "from": "confidence-gateway", "to": "manager-exception-review", "semantics": "Low-confidence or anomalous requests escalated to manager", "conditions": "Confidence score below 95% or anomaly detected" },
      { "id": "c-aiapprove-approved", "from": "ai-auto-approve", "to": "approved", "semantics": "AI-approved request completes with confidence score logged" },
      { "id": "c-exception-approved", "from": "manager-exception-review", "to": "approved", "semantics": "Manager approves exception after review" },
      { "id": "c-exception-rejected", "from": "manager-exception-review", "to": "rejected", "semantics": "Manager rejects flagged exception" },
      { "id": "c-aiapprove-notify", "from": "ai-auto-approve", "to": "ai-notify", "semantics": "Smart notification sent with decision explanation and confidence score" },
      { "id": "c-exception-notify", "from": "manager-exception-review", "to": "ai-notify", "semantics": "Smart notification sent with manager decision and context" }
    ],
    "invariants": [
      "Every phase has at least one path from start to either approved or rejected",
      "No two nodes within the same lane and same phase share the same x coordinate",
      "Every gateway node has at least two outgoing connections",
      "Phase 0 uses only manual tasks with no automated state",
      "Phase 3 achieves at least 85% auto-approval without human intervention",
      "All connections reference nodes that are visible in at least one common phase"
    ]
  }
}