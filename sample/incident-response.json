{
  "title": "IT Incident Response",
  "description": "4-phase transformation from manual phone-tree paging to AI-driven war room with auto-diagnosis and remediation",
  "notes": "Process Owner: IT Operations\nLast Reviewed: 2026-Q1\nSLA Target: MTTR < 5 min (Phase 3)\nEscalation: it-ops@company.com",

  "metrics": {
    "phase0": {
      "stepCount": 8,
      "mttrMinutes": 180,
      "falsePositiveRate": "~35%",
      "escalationRate": "~60%",
      "automationPct": 0,
      "postMortemRate": "~10%"
    },
    "phase1": {
      "stepCount": 7,
      "mttrMinutes": 45,
      "falsePositiveRate": "~18%",
      "escalationRate": "~40%",
      "automationPct": 30,
      "postMortemRate": "~50%"
    },
    "phase2": {
      "stepCount": 7,
      "mttrMinutes": 18,
      "falsePositiveRate": "~5%",
      "escalationRate": "~20%",
      "automationPct": 60,
      "postMortemRate": "~85%"
    },
    "phase3": {
      "stepCount": 6,
      "mttrMinutes": 4,
      "falsePositiveRate": "~1%",
      "escalationRate": "~8%",
      "automationPct": 92,
      "postMortemRate": "100%"
    }
  },

  "phases": [
    { "id": "phase0", "label": "0 -- Manual Paging",       "color": "#6b7280" },
    { "id": "phase1", "label": "1 -- Automated Alerting",  "color": "#3b82f6" },
    { "id": "phase2", "label": "2 -- Auto-Classification", "color": "#8b5cf6" },
    { "id": "phase3", "label": "3 -- AI War Room",         "color": "#10b981" }
  ],

  "lanes": [
    { "id": "monitor",     "label": "Monitoring System", "color": "#1e3a5f", "height": 130 },
    { "id": "oncall",      "label": "On-Call Engineer",  "color": "#1a3a2a", "height": 130 },
    { "id": "team",        "label": "Response Team",     "color": "#3a1a3a", "height": 130 },
    { "id": "stakeholder", "label": "Stakeholders",      "color": "#2a2a1a", "height": 130 }
  ],

  "nodes": [
    { "id": "start",            "type": "start-event",        "label": "Incident\nDetected",         "lane": "monitor",     "x": 100 },

    { "id": "manual-check",     "type": "task",               "label": "Check Dashboard\n(Manual)",  "lane": "monitor",     "x": 260,  "phase": ["phase0"] },
    { "id": "phone-tree",       "type": "task",               "label": "Phone Tree\nPaging",         "lane": "oncall",      "x": 420,  "phase": ["phase0"] },
    { "id": "manual-assess",    "type": "task",               "label": "Assess Severity\n(Manual)",  "lane": "oncall",      "x": 580,  "phase": ["phase0"] },

    { "id": "pagerduty-alert",  "type": "task",               "label": "PagerDuty\nAlert Routing",   "lane": "monitor",     "x": 260,  "phase": ["phase1", "phase2"], "state": "automated" },
    { "id": "basic-dashboard",  "type": "task",               "label": "View Alert\nDashboard",      "lane": "oncall",      "x": 420,  "phase": ["phase1", "phase2"] },
    { "id": "manual-classify",  "type": "task",               "label": "Classify Severity\n(Manual)","lane": "oncall",      "x": 580,  "phase": ["phase1"] },

    { "id": "ai-classify",      "type": "task",               "label": "AI Severity\nClassification","lane": "monitor",     "x": 420,  "phase": ["phase2"], "state": "automated" },
    { "id": "runbook-suggest",  "type": "task",               "label": "Auto-Runbook\nSuggestion",   "lane": "monitor",     "x": 580,  "phase": ["phase2", "phase3"], "state": "automated" },
    { "id": "sla-tracker",      "type": "intermediate-event", "label": "SLA Timer\nStarted",         "lane": "stakeholder", "x": 580,  "phase": ["phase2"] },

    { "id": "ai-commander",     "type": "agent",              "label": "AI Incident\nCommander",     "lane": "monitor",     "x": 260,  "phase": "phase3", "state": "automated" },
    { "id": "auto-diagnose",    "type": "task",               "label": "Auto-Diagnosis",             "lane": "monitor",     "x": 420,  "phase": "phase3", "state": "automated" },
    { "id": "auto-remediate",   "type": "task",               "label": "Auto-Remediate",             "lane": "monitor",     "x": 580,  "phase": "phase3", "state": "automated" },

    { "id": "severity-gw",      "type": "gateway",            "label": "P1?",                        "lane": "oncall",      "x": 720 },
    { "id": "war-room",         "type": "task",               "label": "Assemble\nWar Room",         "lane": "team",        "x": 860,  "phase": ["phase0", "phase1", "phase2"] },
    { "id": "ai-war-room",      "type": "task",               "label": "AI War Room\n(Auto-Convene)","lane": "team",        "x": 860,  "phase": "phase3", "state": "automated" },
    { "id": "resolve",          "type": "task",               "label": "Resolve\nIncident",          "lane": "oncall",      "x": 1000 },
    { "id": "notify-stake",     "type": "intermediate-event", "label": "Notify\nStakeholders",       "lane": "stakeholder", "x": 1000, "phase": "phase1" },
    { "id": "post-mortem",      "type": "task",               "label": "Post-Mortem",                "lane": "team",        "x": 1140, "phase": ["phase1", "phase2"] },
    { "id": "auto-post-mortem", "type": "task",               "label": "AI Post-Mortem\nGeneration", "lane": "team",        "x": 1140, "phase": "phase3", "state": "automated" },
    { "id": "end",              "type": "end-event",           "label": "Closed",                     "lane": "oncall",      "x": 1200 }
  ],

  "connections": [
    { "id": "c-start-manual",       "from": "start",           "to": "manual-check",     "type": "sequence",    "phase": ["phase0"] },
    { "id": "c-manual-phone",       "from": "manual-check",    "to": "phone-tree",       "type": "message",     "phase": ["phase0"] },
    { "id": "c-phone-assess",       "from": "phone-tree",      "to": "manual-assess",    "type": "sequence",    "phase": ["phase0"] },
    { "id": "c-assess-gw",          "from": "manual-assess",   "to": "severity-gw",      "type": "sequence",    "phase": ["phase0"] },

    { "id": "c-start-pager",        "from": "start",           "to": "pagerduty-alert",  "type": "sequence",    "phase": ["phase1", "phase2"] },
    { "id": "c-pager-dash",         "from": "pagerduty-alert", "to": "basic-dashboard",  "type": "sequence",    "phase": ["phase1", "phase2"] },
    { "id": "c-dash-classify",      "from": "basic-dashboard", "to": "manual-classify",  "type": "sequence",    "phase": ["phase1"] },
    { "id": "c-classify-gw",        "from": "manual-classify", "to": "severity-gw",      "type": "sequence",    "phase": ["phase1"] },
    { "id": "c-dash-aiclass",       "from": "basic-dashboard", "to": "ai-classify",      "type": "sequence",    "phase": ["phase2"] },
    { "id": "c-aiclass-runbook",    "from": "ai-classify",     "to": "runbook-suggest",  "type": "sequence",    "phase": ["phase2"] },
    { "id": "c-diagnose-runbook",   "from": "auto-diagnose",   "to": "runbook-suggest",  "type": "message",     "phase": "phase3" },
    { "id": "c-runbook-gw",         "from": "runbook-suggest", "to": "severity-gw",      "type": "sequence",    "phase": ["phase2", "phase3"] },
    { "id": "c-aiclass-sla",        "from": "ai-classify",     "to": "sla-tracker",      "type": "message",     "phase": ["phase2"] },

    { "id": "c-start-commander",    "from": "start",           "to": "ai-commander",     "type": "sequence",    "phase": "phase3" },
    { "id": "c-commander-diagnose", "from": "ai-commander",    "to": "auto-diagnose",    "type": "sequence",    "phase": "phase3" },
    { "id": "c-diagnose-remediate", "from": "auto-diagnose",   "to": "auto-remediate",   "type": "sequence",    "phase": "phase3" },
    { "id": "c-remediate-gw",       "from": "auto-remediate",  "to": "severity-gw",      "type": "sequence",    "phase": "phase3" },

    { "id": "c-gw-war",             "from": "severity-gw",     "to": "war-room",         "type": "sequence",    "phase": ["phase0", "phase1", "phase2"], "decision": "yes", "label": "P1" },
    { "id": "c-gw-aiwar",           "from": "severity-gw",     "to": "ai-war-room",      "type": "sequence",    "phase": "phase3", "decision": "yes", "label": "P1" },
    { "id": "c-gw-resolve",         "from": "severity-gw",     "to": "resolve",          "type": "sequence",    "decision": "no",  "label": "P2/P3" },
    { "id": "c-war-resolve",        "from": "war-room",        "to": "resolve",          "type": "sequence",    "phase": ["phase0", "phase1", "phase2"] },
    { "id": "c-aiwar-resolve",      "from": "ai-war-room",     "to": "resolve",          "type": "sequence",    "phase": "phase3" },
    { "id": "c-war-notify",         "from": "war-room",        "to": "notify-stake",     "type": "message",     "phase": ["phase1", "phase2"] },
    { "id": "c-aiwar-notify",       "from": "ai-war-room",     "to": "notify-stake",     "type": "message",     "phase": "phase3" },
    { "id": "c-resolve-pm",         "from": "resolve",         "to": "post-mortem",      "type": "sequence",    "phase": ["phase1", "phase2"] },
    { "id": "c-resolve-autopm",     "from": "resolve",         "to": "auto-post-mortem", "type": "sequence",    "phase": "phase3" },
    { "id": "c-resolve-end",        "from": "resolve",         "to": "end",              "type": "sequence",    "phase": ["phase0"] },
    { "id": "c-pm-end",             "from": "post-mortem",     "to": "end",              "type": "sequence",    "phase": ["phase1", "phase2"] },
    { "id": "c-autopm-end",         "from": "auto-post-mortem","to": "end",              "type": "sequence",    "phase": "phase3" },
    { "id": "c-notify-end",         "from": "notify-stake",    "to": "end",              "type": "sequence",    "phase": "phase1" },
    { "id": "c-sla-end",            "from": "sla-tracker",     "to": "end",              "type": "message",     "phase": ["phase2"], "style": "dashed" }
  ],

  "sequence": [
    { "from": "start",          "to": "ai-commander",    "text": "Anomaly detected by monitoring",           "status": "ready" },
    { "from": "ai-commander",   "to": "auto-diagnose",   "text": "AI commander takes over triage",           "status": "ready" },
    { "from": "auto-diagnose",  "to": "auto-remediate",  "text": "Root cause identified automatically",      "status": "wip",
      "popup": { "type": "issue", "msg": "P1 Critical: 99% confidence — DB connection pool exhaustion" } },
    { "from": "auto-remediate", "to": "severity-gw",     "text": "Auto-remediation attempted",               "status": "ready" },
    { "from": "severity-gw",    "to": "ai-war-room",     "text": "P1 escalated — AI convenes war room",      "status": "ready" },
    { "from": "ai-war-room",    "to": "resolve",         "text": "War room resolves remaining issues",       "status": "wip" },
    { "from": "resolve",        "to": "auto-post-mortem","text": "Resolved — AI generates post-mortem",      "status": "ready",
      "popup": { "type": "amplify", "msg": "MTTR: 4 minutes — AI-driven" } }
  ],

  "spec": {
    "schemaVersion": "2.0",
    "description": "IT incident response evolving across 4 phases: manual phone-tree paging (phase0), PagerDuty automated alerting (phase1), AI severity classification with SLA tracking (phase2), and full AI war room with auto-diagnosis and remediation (phase3).",
    "nodeInventory": [
      { "id": "start",            "type": "start-event",        "lane": "monitor",     "phase": "all",    "role": "Triggers incident response when anomaly detected",                           "critical": true  },
      { "id": "manual-check",     "type": "task",               "lane": "monitor",     "phase": "phase0", "role": "Engineer manually scans monitoring dashboard for alerts",                     "critical": true  },
      { "id": "phone-tree",       "type": "task",               "lane": "oncall",      "phase": "phase0", "role": "On-call paged via manual phone tree — slow, error-prone",                    "critical": true  },
      { "id": "manual-assess",    "type": "task",               "lane": "oncall",      "phase": "phase0", "role": "Severity assessed manually without tooling — subjective and inconsistent",    "critical": true  },
      { "id": "pagerduty-alert",  "type": "task",               "lane": "monitor",     "phase": "phase1+","role": "PagerDuty integration routes alerts automatically to on-call rotations",      "critical": true  },
      { "id": "basic-dashboard",  "type": "task",               "lane": "oncall",      "phase": "phase1-2","role": "Engineer views structured alert dashboard with context and history",          "critical": true  },
      { "id": "manual-classify",  "type": "task",               "lane": "oncall",      "phase": "phase1", "role": "Engineer manually classifies severity using dashboard data",                  "critical": true  },
      { "id": "ai-classify",      "type": "task",               "lane": "monitor",     "phase": "phase2+","role": "AI model classifies severity with confidence score and historical correlation","critical": true  },
      { "id": "runbook-suggest",  "type": "task",               "lane": "monitor",     "phase": "phase2-3","role": "System suggests relevant runbooks based on incident classification",          "critical": false },
      { "id": "sla-tracker",      "type": "intermediate-event", "lane": "stakeholder", "phase": "phase2+","role": "SLA countdown timer started — stakeholders track resolution progress",        "critical": false },
      { "id": "ai-commander",     "type": "agent",              "lane": "monitor",     "phase": "phase3", "role": "AI incident commander orchestrates full triage and response automatically",    "critical": true  },
      { "id": "auto-diagnose",    "type": "task",               "lane": "monitor",     "phase": "phase3", "role": "Automated root-cause analysis using logs, metrics, and trace correlation",     "critical": true  },
      { "id": "auto-remediate",   "type": "task",               "lane": "monitor",     "phase": "phase3", "role": "Automated remediation applied — rollback, scale-out, config fix",              "critical": true  },
      { "id": "severity-gw",      "type": "gateway",            "lane": "oncall",      "phase": "all",    "role": "Routes P1 to war room path, P2/P3 directly to resolution",                   "critical": true  },
      { "id": "war-room",         "type": "task",               "lane": "team",        "phase": "phase0-2","role": "Response team manually assembled for P1 critical incidents",                  "critical": true  },
      { "id": "ai-war-room",      "type": "task",               "lane": "team",        "phase": "phase3", "role": "AI auto-convenes war room with relevant engineers and context pre-loaded",     "critical": true  },
      { "id": "resolve",          "type": "task",               "lane": "oncall",      "phase": "all",    "role": "Incident resolved — human or AI-assisted depending on phase",                 "critical": true  },
      { "id": "notify-stake",     "type": "intermediate-event", "lane": "stakeholder", "phase": "phase1+","role": "Automated stakeholder notification with status updates",                      "critical": false },
      { "id": "post-mortem",      "type": "task",               "lane": "team",        "phase": "phase1-2","role": "Manual blameless post-mortem scheduled and conducted after resolution",       "critical": true  },
      { "id": "auto-post-mortem", "type": "task",               "lane": "team",        "phase": "phase3", "role": "AI generates comprehensive post-mortem with timeline and recommendations",     "critical": true  },
      { "id": "end",              "type": "end-event",           "lane": "oncall",      "phase": "all",    "role": "Incident formally closed with audit trail",                                   "critical": false }
    ],
    "connectionInventory": [
      { "id": "c-start-manual",       "from": "start",           "to": "manual-check",     "semantics": "Phase 0: monitoring triggers manual dashboard check" },
      { "id": "c-manual-phone",       "from": "manual-check",    "to": "phone-tree",       "semantics": "Alert found — engineer calls phone tree to page on-call" },
      { "id": "c-phone-assess",       "from": "phone-tree",      "to": "manual-assess",    "semantics": "On-call responds — begins manual severity assessment" },
      { "id": "c-assess-gw",          "from": "manual-assess",   "to": "severity-gw",      "semantics": "Assessment complete — routed to severity gateway" },
      { "id": "c-start-pager",        "from": "start",           "to": "pagerduty-alert",  "semantics": "Phase 1-2: alert auto-routed through PagerDuty" },
      { "id": "c-pager-dash",         "from": "pagerduty-alert", "to": "basic-dashboard",  "semantics": "PagerDuty dispatches — engineer views alert dashboard" },
      { "id": "c-dash-classify",      "from": "basic-dashboard", "to": "manual-classify",  "semantics": "Phase 1: engineer manually classifies from dashboard" },
      { "id": "c-classify-gw",        "from": "manual-classify", "to": "severity-gw",      "semantics": "Classification done — severity routed to gateway" },
      { "id": "c-dash-aiclass",       "from": "basic-dashboard", "to": "ai-classify",      "semantics": "Phase 2: dashboard feeds AI classifier for auto-severity" },
      { "id": "c-aiclass-runbook",    "from": "ai-classify",     "to": "runbook-suggest",  "semantics": "AI classification triggers runbook recommendation" },
      { "id": "c-runbook-gw",         "from": "runbook-suggest", "to": "severity-gw",      "semantics": "Runbook suggested — severity routed to gateway" },
      { "id": "c-aiclass-sla",        "from": "ai-classify",     "to": "sla-tracker",      "semantics": "AI classification starts SLA countdown for stakeholders" },
      { "id": "c-start-commander",    "from": "start",           "to": "ai-commander",     "semantics": "Phase 3: AI commander immediately takes over triage" },
      { "id": "c-commander-diagnose", "from": "ai-commander",    "to": "auto-diagnose",    "semantics": "Commander initiates automated root-cause diagnosis" },
      { "id": "c-diagnose-remediate", "from": "auto-diagnose",   "to": "auto-remediate",   "semantics": "Diagnosis complete — auto-remediation attempted" },
      { "id": "c-remediate-gw",       "from": "auto-remediate",  "to": "severity-gw",      "semantics": "Remediation result evaluated — escalation check" },
      { "id": "c-gw-war",             "from": "severity-gw",     "to": "war-room",         "semantics": "P1 critical — manual war room assembled",              "conditions": "Severity = P1, Phase 0-2" },
      { "id": "c-gw-aiwar",           "from": "severity-gw",     "to": "ai-war-room",      "semantics": "P1 critical — AI auto-convenes war room",              "conditions": "Severity = P1, Phase 3" },
      { "id": "c-gw-resolve",         "from": "severity-gw",     "to": "resolve",          "semantics": "P2/P3 routed directly to on-call resolution",          "conditions": "Severity = P2 or P3" },
      { "id": "c-war-resolve",        "from": "war-room",        "to": "resolve",          "semantics": "War room drives resolution for Phase 0-2" },
      { "id": "c-aiwar-resolve",      "from": "ai-war-room",     "to": "resolve",          "semantics": "AI war room drives resolution for Phase 3" },
      { "id": "c-war-notify",         "from": "war-room",        "to": "notify-stake",     "semantics": "War room triggers stakeholder notification (Phase 1-2)" },
      { "id": "c-aiwar-notify",       "from": "ai-war-room",     "to": "notify-stake",     "semantics": "AI war room auto-notifies stakeholders (Phase 3)" },
      { "id": "c-resolve-pm",         "from": "resolve",         "to": "post-mortem",      "semantics": "Resolution triggers manual post-mortem (Phase 1-2)" },
      { "id": "c-resolve-autopm",     "from": "resolve",         "to": "auto-post-mortem", "semantics": "Resolution triggers AI post-mortem generation (Phase 3)" },
      { "id": "c-resolve-end",        "from": "resolve",         "to": "end",              "semantics": "Phase 0: resolve goes directly to close (no post-mortem)" },
      { "id": "c-pm-end",             "from": "post-mortem",     "to": "end",              "semantics": "Post-mortem complete — incident closed (Phase 1-2)" },
      { "id": "c-autopm-end",         "from": "auto-post-mortem","to": "end",              "semantics": "AI post-mortem generated — incident closed (Phase 3)" },
      { "id": "c-notify-end",         "from": "notify-stake",    "to": "end",              "semantics": "Stakeholder notification dispatched — feeds into close" },
      { "id": "c-sla-end",            "from": "sla-tracker",     "to": "end",              "semantics": "SLA tracker resolves when incident closed" }
    ],
    "behaviors": [
      {
        "id": "beh-phase0-manual-flow",
        "trigger": "Phase slider at 0",
        "expectedOutcome": "Only manual paging path visible: start -> manual-check -> phone-tree -> manual-assess -> severity-gw -> war-room/resolve -> end",
        "involvedNodes": ["start", "manual-check", "phone-tree", "manual-assess", "severity-gw", "war-room", "resolve", "end"],
        "testRef": "IR-P0"
      },
      {
        "id": "beh-phase1-pagerduty",
        "trigger": "Phase slider at 1",
        "expectedOutcome": "PagerDuty path visible with manual classification, stakeholder notifications, and post-mortem added",
        "involvedNodes": ["start", "pagerduty-alert", "basic-dashboard", "manual-classify", "severity-gw", "war-room", "resolve", "notify-stake", "post-mortem", "end"],
        "testRef": "IR-P1"
      },
      {
        "id": "beh-phase2-aiclass",
        "trigger": "Phase slider at 2",
        "expectedOutcome": "AI classification replaces manual, runbook suggestions and SLA tracking appear",
        "involvedNodes": ["start", "pagerduty-alert", "basic-dashboard", "ai-classify", "runbook-suggest", "sla-tracker", "severity-gw", "war-room", "resolve", "notify-stake", "post-mortem", "end"],
        "testRef": "IR-P2"
      },
      {
        "id": "beh-phase3-aiwar",
        "trigger": "Phase slider at 3",
        "expectedOutcome": "Full AI pipeline: commander -> diagnose -> remediate, AI war room, auto post-mortem generation",
        "involvedNodes": ["start", "ai-commander", "auto-diagnose", "auto-remediate", "runbook-suggest", "severity-gw", "ai-war-room", "resolve", "notify-stake", "auto-post-mortem", "end"],
        "testRef": "IR-P3"
      },
      {
        "id": "beh-severity-routing",
        "trigger": "Severity gateway evaluated at any phase",
        "expectedOutcome": "P1 always routes to war room (manual or AI), P2/P3 always routes direct to resolve",
        "involvedNodes": ["severity-gw", "war-room", "ai-war-room", "resolve"],
        "testRef": "IR-GW"
      }
    ],
    "invariants": [
      "Every path from start reaches end in all four phases",
      "P1 path always involves a war room (manual in phase 0-2, AI in phase 3)",
      "P2/P3 path always routes directly to resolve without war room",
      "No two node bounding boxes overlap within the same phase",
      "Post-mortem exists in phase 1+ (manual in 1-2, AI-generated in 3)",
      "Stakeholder notifications exist in phase 1+ only",
      "All node x coordinates are multiples of 20"
    ]
  }
}
