{
  "title": "Lean Six Sigma: Warranty Claim Processing",
  "subtitle": "DMAIC 4-phase transformation -- from manual defect tracking to AI poka-yoke",

  "phases": [
    { "id": "phase0", "label": "0 -- Manual Quality",      "color": "#6b7280" },
    { "id": "phase1", "label": "1 -- Data Collection",     "color": "#3b82f6" },
    { "id": "phase2", "label": "2 -- Statistical Control",  "color": "#8b5cf6" },
    { "id": "phase3", "label": "3 -- AI Poka-Yoke",        "color": "#10b981" }
  ],

  "lanes": [
    { "id": "customer",   "label": "Customer",    "color": "#1e3a5f", "height": 110 },
    { "id": "quality",    "label": "Quality",     "color": "#2a1a3a", "height": 130 },
    { "id": "production", "label": "Production",  "color": "#1a2a2a", "height": 130 },
    { "id": "management", "label": "Management",  "color": "#2a2010", "height": 110 }
  ],

  "metrics": {
    "phase0": { "cycleTime": "18 days",   "defectRate": "28%",  "firstPass": "42%",  "automation": "0%",   "costPerClaim": "$210" },
    "phase1": { "cycleTime": "10 days",   "defectRate": "18%",  "firstPass": "60%",  "automation": "20%",  "costPerClaim": "$140" },
    "phase2": { "cycleTime": "5 days",    "defectRate": "8%",   "firstPass": "78%",  "automation": "55%",  "costPerClaim": "$72" },
    "phase3": { "cycleTime": "2.5 days",  "defectRate": "3%",   "firstPass": "91%",  "automation": "85%",  "costPerClaim": "$28" }
  },

  "nodes": [
    { "id": "start",            "type": "start-event",       "label": "Claim\nReceived",              "lane": "customer",    "x": 100 },
    { "id": "end",              "type": "end-event",         "label": "Claim\nClosed",                "lane": "customer",    "x": 1400 },

    { "id": "phone-intake",     "type": "task",              "label": "Phone / Email\nIntake",        "lane": "customer",    "x": 240,   "phase": ["phase0"] },
    { "id": "paper-form",       "type": "task",              "label": "Paper Form\nEntry",            "lane": "quality",     "x": 380,   "phase": ["phase0"] },
    { "id": "paper-checklist",  "type": "task",              "label": "Paper Defect\nChecklist",      "lane": "quality",     "x": 520,   "phase": ["phase0"] },
    { "id": "manual-inspect",   "type": "task",              "label": "Manual\nInspection",           "lane": "production",  "x": 660,   "phase": ["phase0"] },
    { "id": "reactive-fix",     "type": "task",              "label": "Reactive\nRepair",             "lane": "production",  "x": 800,   "phase": ["phase0"] },
    { "id": "manual-close",     "type": "task",              "label": "Manual Closure\nPaperwork",    "lane": "management",  "x": 960,   "phase": ["phase0"] },
    { "id": "letter-notify",    "type": "task",              "label": "Letter /\nPhone Call",         "lane": "customer",    "x": 1120,  "phase": ["phase0"] },
    { "id": "note-errors",      "type": "annotation",        "label": "28% data entry errors\nno real-time validation",  "lane": "quality",  "x": 520,  "phase": ["phase0"] },

    { "id": "web-form",         "type": "task",              "label": "Digital Web\nForm",            "lane": "customer",    "x": 240,   "phase": ["phase1", "phase2"] },
    { "id": "digital-log",      "type": "task",              "label": "Digital Defect\nLog",          "lane": "quality",     "x": 380,   "phase": ["phase1"] },
    { "id": "categorize",       "type": "task",              "label": "Defect\nCategorization",       "lane": "quality",     "x": 520,   "phase": ["phase1"] },
    { "id": "basic-dashboard",  "type": "system",            "label": "Basic\nDashboard",             "lane": "management",  "x": 660,   "phase": ["phase1"] },

    { "id": "gw-eligible",      "type": "gateway",           "label": "Eligible?",                    "lane": "quality",     "x": 660,   "phase": "phase1" },
    { "id": "reject-email",     "type": "task",              "label": "Rejection\nEmail",             "lane": "quality",     "x": 800,   "phase": ["phase1", "phase2"] },
    { "id": "manual-route",     "type": "task",              "label": "Manual\nRouting",              "lane": "production",  "x": 800,   "phase": ["phase1"] },
    { "id": "tech-diagnose",    "type": "task",              "label": "Technician\nDiagnosis",        "lane": "production",  "x": 940,   "phase": ["phase1", "phase2"] },
    { "id": "gw-fixable",       "type": "gateway",           "label": "Fixable?",                     "lane": "production",  "x": 1080, "phase": "phase1" },
    { "id": "repair-task",      "type": "task",              "label": "Manual\nRepair",               "lane": "production",  "x": 1240,  "phase": ["phase1", "phase2"] },
    { "id": "replace-task",     "type": "task",              "label": "Manual\nReplacement",          "lane": "production",  "x": 1240,  "phase": ["phase1", "phase2"] },
    { "id": "digital-close",    "type": "task",              "label": "Digital\nClosure Log",         "lane": "management",  "x": 1120,  "phase": ["phase1", "phase2"] },
    { "id": "email-notify",     "type": "task",              "label": "Email\nNotification",          "lane": "customer",    "x": 1260,  "phase": ["phase1", "phase2"] },

    { "id": "spc-engine",       "type": "system",            "label": "SPC\nEngine",                  "lane": "quality",     "x": 380,   "phase": ["phase2"] },
    { "id": "control-chart",    "type": "system",            "label": "Control\nCharts",              "lane": "management",  "x": 520,   "phase": ["phase2"] },
    { "id": "alert-system",     "type": "system",            "label": "Out-of-Spec\nAlerts",          "lane": "quality",     "x": 520,   "phase": ["phase2"] },
    { "id": "auto-eligibility", "type": "system",            "label": "Automated\nEligibility Rules", "lane": "quality",     "x": 660,   "phase": ["phase2"] },
    { "id": "smart-route",      "type": "system",            "label": "Smart\nRouting",               "lane": "production",  "x": 800,   "phase": ["phase2"] },
    { "id": "audit-close",      "type": "system",            "label": "Closure &\nAudit System",      "lane": "management",  "x": 1120,  "phase": ["phase2"] },

    { "id": "self-service",     "type": "persona",           "label": "Customer\nSelf-Service",       "lane": "customer",    "x": 240,   "phase": "phase3" },
    { "id": "intake-agent",     "type": "agent",             "label": "Intake\nStation Agent",        "lane": "quality",     "x": 380,   "phase": "phase3" },
    { "id": "poka-yoke",        "type": "system",            "label": "Poka-Yoke\nValidation\nEngine","lane": "quality",     "x": 520,   "phase": "phase3" },
    { "id": "gw-data-ok",       "type": "gateway",           "label": "Data\nComplete?",              "lane": "quality",     "x": 660,   "phase": "phase3" },
    { "id": "auto-fix-agent",   "type": "agent",             "label": "Auto-Fix &\nPrompt Agent",     "lane": "quality",     "x": 800,   "phase": "phase3" },
    { "id": "ai-eligibility",   "type": "system",            "label": "AI Eligibility\nRules",        "lane": "quality",     "x": 660,   "phase": "phase3" },
    { "id": "ai-reject-agent",  "type": "agent",             "label": "Auto-Reject\nAgent",           "lane": "quality",     "x": 800,   "phase": "phase3" },
    { "id": "diag-agent",       "type": "agent",             "label": "Diagnostic\nAgent",            "lane": "production",  "x": 940,   "phase": "phase3" },
    { "id": "repair-station",   "type": "subprocess",        "label": "Repair\nStation",              "lane": "production",  "x": 1240,  "phase": "phase3", "state": "automated" },
    { "id": "replace-station",  "type": "subprocess",        "label": "Replacement\nStation",         "lane": "production",  "x": 1240,  "phase": "phase3", "state": "automated" },
    { "id": "predictive-maint", "type": "system",            "label": "Predictive\nMaintenance",      "lane": "production",  "x": 800,   "phase": "phase3" },
    { "id": "quality-score",    "type": "system",            "label": "Real-Time\nQuality Score",     "lane": "management",  "x": 940,   "phase": "phase3" },
    { "id": "ai-close",         "type": "system",            "label": "AI Closure &\nAudit",          "lane": "management",  "x": 1120,  "phase": "phase3" },
    { "id": "notify-agent",     "type": "agent",             "label": "Notification\nAgent",          "lane": "customer",    "x": 1260,  "phase": "phase3" }
  ],

  "connections": [
    { "id": "c-start-phone",       "from": "start",           "to": "phone-intake",    "type": "sequence", "phase": ["phase0"] },
    { "id": "c-phone-paper",       "from": "phone-intake",    "to": "paper-form",      "type": "sequence", "phase": ["phase0"] },
    { "id": "c-paper-checklist",   "from": "paper-form",      "to": "paper-checklist", "type": "sequence", "phase": ["phase0"] },
    { "id": "c-checklist-inspect", "from": "paper-checklist",  "to": "manual-inspect", "type": "message",  "phase": ["phase0"] },
    { "id": "c-inspect-fix",       "from": "manual-inspect",  "to": "reactive-fix",    "type": "sequence", "phase": ["phase0"] },
    { "id": "c-fix-close",         "from": "reactive-fix",    "to": "manual-close",    "type": "sequence", "phase": ["phase0"] },
    { "id": "c-close-letter",      "from": "manual-close",    "to": "letter-notify",   "type": "sequence", "phase": ["phase0"] },
    { "id": "c-letter-end",        "from": "letter-notify",   "to": "end",             "type": "sequence", "phase": ["phase0"] },

    { "id": "c-start-web",         "from": "start",           "to": "web-form",        "type": "sequence", "phase": ["phase1"] },
    { "id": "c-web-log",           "from": "web-form",        "to": "digital-log",     "type": "sequence", "phase": ["phase1"] },
    { "id": "c-log-cat",           "from": "digital-log",     "to": "categorize",      "type": "sequence", "phase": ["phase1"] },
    { "id": "c-cat-elig",          "from": "categorize",      "to": "gw-eligible",     "type": "sequence", "phase": ["phase1"] },
    { "id": "c-elig-reject1",      "from": "gw-eligible",     "to": "reject-email",    "type": "sequence", "phase": ["phase1", "phase2"], "decision": "no",  "label": "No" },
    { "id": "c-elig-route",        "from": "gw-eligible",     "to": "manual-route",    "type": "sequence", "phase": ["phase1"],            "decision": "yes", "label": "Yes" },
    { "id": "c-route-diag",        "from": "manual-route",    "to": "tech-diagnose",   "type": "message",  "phase": ["phase1"] },
    { "id": "c-diag-fix1",         "from": "tech-diagnose",   "to": "gw-fixable",      "type": "sequence", "phase": ["phase1", "phase2"] },
    { "id": "c-fix-repair1",       "from": "gw-fixable",      "to": "repair-task",     "type": "sequence", "phase": ["phase1", "phase2"], "decision": "yes", "label": "Repair" },
    { "id": "c-fix-replace1",      "from": "gw-fixable",      "to": "replace-task",    "type": "sequence", "phase": ["phase1", "phase2"], "decision": "no",  "label": "Replace" },
    { "id": "c-repair-close1",     "from": "repair-task",     "to": "digital-close",   "type": "sequence", "phase": ["phase1", "phase2"] },
    { "id": "c-replace-close1",    "from": "replace-task",    "to": "digital-close",   "type": "sequence", "phase": ["phase1", "phase2"] },
    { "id": "c-close-email1",      "from": "digital-close",   "to": "email-notify",    "type": "sequence", "phase": ["phase1", "phase2"] },
    { "id": "c-email-end1",        "from": "email-notify",    "to": "end",             "type": "sequence", "phase": ["phase1", "phase2"] },
    { "id": "c-reject-email1",     "from": "reject-email",    "to": "email-notify",    "type": "sequence", "phase": ["phase1", "phase2"] },
    { "id": "c-log-dash",          "from": "digital-log",     "to": "basic-dashboard", "type": "message",  "phase": ["phase1"] },

    { "id": "c-start-web2",        "from": "start",           "to": "web-form",        "type": "sequence", "phase": ["phase2"] },
    { "id": "c-web-spc",           "from": "web-form",        "to": "spc-engine",      "type": "sequence", "phase": ["phase2"] },
    { "id": "c-spc-alert",         "from": "spc-engine",      "to": "alert-system",    "type": "message",  "phase": ["phase2"] },
    { "id": "c-spc-chart",         "from": "spc-engine",      "to": "control-chart",   "type": "message",  "phase": ["phase2"] },
    { "id": "c-spc-elig",          "from": "spc-engine",      "to": "auto-eligibility","type": "sequence", "phase": ["phase2"] },
    { "id": "c-autoelig-gw",       "from": "auto-eligibility","to": "gw-eligible",     "type": "sequence", "phase": ["phase2"] },
    { "id": "c-elig-smart",        "from": "gw-eligible",     "to": "smart-route",     "type": "sequence", "phase": ["phase2"],            "decision": "yes", "label": "Yes" },
    { "id": "c-smart-diag",        "from": "smart-route",     "to": "tech-diagnose",   "type": "message",  "phase": ["phase2"] },
    { "id": "c-audit-email",       "from": "audit-close",     "to": "email-notify",    "type": "sequence", "phase": ["phase2"] },
    { "id": "c-repair-audit",      "from": "repair-task",     "to": "audit-close",     "type": "sequence", "phase": ["phase2"] },
    { "id": "c-replace-audit",     "from": "replace-task",    "to": "audit-close",     "type": "sequence", "phase": ["phase2"] },

    { "id": "c-start-self",        "from": "start",           "to": "self-service",    "type": "sequence", "phase": "phase3" },
    { "id": "c-self-intake",       "from": "self-service",    "to": "intake-agent",    "type": "message",  "phase": "phase3" },
    { "id": "c-intake-poka",       "from": "intake-agent",    "to": "poka-yoke",       "type": "message",  "phase": "phase3" },
    { "id": "c-poka-gw",           "from": "poka-yoke",       "to": "gw-data-ok",      "type": "sequence", "phase": "phase3" },
    { "id": "c-gw-fix",            "from": "gw-data-ok",      "to": "auto-fix-agent",  "type": "sequence", "phase": "phase3",              "decision": "no",  "label": "Gaps" },
    { "id": "c-fix-poka",          "from": "auto-fix-agent",  "to": "poka-yoke",       "type": "sequence", "phase": "phase3" },
    { "id": "c-gw-aielig",         "from": "gw-data-ok",      "to": "ai-eligibility",  "type": "message",  "phase": "phase3",              "decision": "yes", "label": "OK" },
    { "id": "c-aielig-gw",         "from": "ai-eligibility",  "to": "gw-eligible",     "type": "sequence", "phase": "phase3" },
    { "id": "c-elig-aireject",     "from": "gw-eligible",     "to": "ai-reject-agent", "type": "sequence", "phase": "phase3",              "decision": "no",  "label": "No" },
    { "id": "c-elig-diag",         "from": "gw-eligible",     "to": "diag-agent",      "type": "sequence", "phase": "phase3",              "decision": "yes", "label": "Yes" },
    { "id": "c-diag-predict",      "from": "diag-agent",      "to": "predictive-maint","type": "message",  "phase": "phase3" },
    { "id": "c-diag-fix3",         "from": "diag-agent",      "to": "gw-fixable",      "type": "sequence", "phase": "phase3" },
    { "id": "c-fix-repair3",       "from": "gw-fixable",      "to": "repair-station",  "type": "sequence", "phase": "phase3",              "decision": "yes", "label": "Repair" },
    { "id": "c-fix-replace3",      "from": "gw-fixable",      "to": "replace-station", "type": "sequence", "phase": "phase3",              "decision": "no",  "label": "Replace" },
    { "id": "c-repair-qscore",     "from": "repair-station",  "to": "quality-score",   "type": "message",  "phase": "phase3" },
    { "id": "c-replace-qscore",    "from": "replace-station", "to": "quality-score",   "type": "message",  "phase": "phase3" },
    { "id": "c-repair-aiclose",    "from": "repair-station",  "to": "ai-close",        "type": "sequence", "phase": "phase3" },
    { "id": "c-replace-aiclose",   "from": "replace-station", "to": "ai-close",        "type": "sequence", "phase": "phase3" },
    { "id": "c-aireject-notify",   "from": "ai-reject-agent", "to": "notify-agent",    "type": "message",  "phase": "phase3" },
    { "id": "c-aiclose-notify",    "from": "ai-close",        "to": "notify-agent",    "type": "message",  "phase": "phase3" },
    { "id": "c-notify-end",        "from": "notify-agent",    "to": "end",             "type": "sequence", "phase": "phase3" }
  ],

  "story": {
    "title": "DMAIC Happy Path: AI Poka-Yoke Claim",
    "description": "A warranty claim enters via the self-service portal. The Poka-Yoke engine catches missing fields immediately. AI eligibility decides in <1s. The Diagnostic Agent classifies the fault and routes to the correct station. Real-time quality scoring and predictive maintenance feed continuous improvement. Closure and notification fire automatically.",
    "sequence": [
      { "from": "start",          "to": "self-service",    "text": "Customer opens warranty portal -- structured form, no phone calls",        "status": "ready" },
      { "from": "self-service",   "to": "intake-agent",    "text": "Portal submits claim to Intake Station Agent",                             "status": "ready" },
      { "from": "intake-agent",   "to": "poka-yoke",       "text": "Poka-Yoke engine validates 23 mandatory fields in real time",              "status": "wip",
        "popup": { "type": "amplify", "msg": "All 23 fields validated -- zero errors detected" } },
      { "from": "poka-yoke",      "to": "gw-data-ok",      "text": "Data complete -- forwarding to eligibility check",                        "status": "ready" },
      { "from": "gw-data-ok",     "to": "ai-eligibility",  "text": "Data OK -> AI Eligibility Rules queried",                                 "status": "ready" },
      { "from": "ai-eligibility", "to": "gw-eligible",     "text": "AI rules engine: claim within warranty window, serial verified",           "status": "wip",
        "popup": { "type": "amplify", "msg": "Eligibility: PASS (0.2s)" } },
      { "from": "gw-eligible",    "to": "diag-agent",      "text": "Eligible -> Diagnostic Agent analyses fault code and history",             "status": "ready" },
      { "from": "diag-agent",     "to": "gw-fixable",      "text": "Diagnosis: component failure -- repairable",                              "status": "wip" },
      { "from": "gw-fixable",     "to": "repair-station",  "text": "Claim routed to Repair Station (SLA: 1 business day)",                    "status": "wip" },
      { "from": "repair-station", "to": "ai-close",        "text": "Repair complete -- AI Closure & Audit records outcome",                   "status": "ready" },
      { "from": "ai-close",       "to": "notify-agent",    "text": "Audit passed -- Notification Agent fires SMS + email with tracking",      "status": "ready",
        "popup": { "type": "amplify", "msg": "Claim closed in 2.5 days -- CSAT score: 9.2/10" } }
    ]
  },

  "spec": {
    "schemaVersion": "2.0",
    "dmaic": {
      "define":   "High defect rate (28%), long cycle time (18 days) in warranty claim processing -- sourced from CSAT surveys and ops data",
      "measure":  "Baseline: 42% first-pass yield, 28% data-entry error rate, 18-day average cycle time, $210 cost per claim",
      "analyse":  "Root causes: unstructured phone intake, no real-time validation (poka-yoke absent), manual eligibility lookup with no SLA, ad-hoc routing with no skill-based assignment",
      "improve":  "Phase 1: digital forms and dashboards. Phase 2: SPC engine, control charts, automated alerts. Phase 3: AI poka-yoke, predictive maintenance, real-time quality scoring, auto-corrective action",
      "control":  "Phase 3 stations enforce hard SLAs; AI Closure & Audit System logs every decision; control charts run continuously; predictive maintenance prevents recurring defects"
    },
    "wasteEliminated": [
      { "waste": "Defects",        "phase0": "28% data entry error rate",      "phase3": "~3% (poka-yoke prevented at source)" },
      { "waste": "Waiting",        "phase0": "30 min eligibility queue",       "phase3": "<1s automated AI rules check" },
      { "waste": "Motion",         "phase0": "Customer phone call + paper",    "phase3": "Self-service portal" },
      { "waste": "Overprocessing", "phase0": "Re-diagnosis per technician",    "phase3": "AI Diagnostic Agent with knowledge base" },
      { "waste": "Inventory",      "phase0": "Manual part pick, no ERP",       "phase3": "Real-time ERP integration in Replacement Station" }
    ],
    "invariants": [
      "The Poka-Yoke engine must sit BEFORE the Eligibility gateway -- data quality is gate 1",
      "The fix-data loop (auto-fix-agent -> poka-yoke) must re-enter the validation engine, not skip it",
      "Repair and Replacement stations both converge into the same Closure & Audit node",
      "Phase 0 uses only task and annotation types -- zero agents or systems",
      "Phase 3 replaces all manual tasks with agent, system, or subprocess types"
    ]
  }
}