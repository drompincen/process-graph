  "story": {
    "title": "DMAIC Happy Path: Lean Claim",
    "description": "A warranty claim enters via the self-service portal. The Poka-Yoke engine catches missing fields immediately. Eligibility is decided in <1s. The Diagnostic Agent classifies the fault and routes to the correct station. Closure and notification fire automatically.",
    "sequence": [
      { "from": "a-start",      "to": "a-cust",       "text": "Customer opens warranty portal — structured form, no phone calls",        "status": "ready" },
      { "from": "a-cust",       "to": "a-intake-agt", "text": "Portal submits claim to Intake Station Agent",                             "status": "ready" },
      { "from": "a-intake-agt", "to": "a-poka-yoke",  "text": "Poka-Yoke engine validates 23 mandatory fields in real time",              "status": "wip",
        "popup": { "type": "amplify", "msg": "All 23 fields validated — zero errors detected" } },
      { "from": "a-poka-yoke",  "to": "a-gw-data",    "text": "Data complete — forwarding to eligibility check",                          "status": "ready" },
      { "from": "a-gw-data",    "to": "a-elig-sys",   "text": "Data OK → Eligibility Rules System queried",                               "status": "ready" },
      { "from": "a-elig-sys",   "to": "a-gw-elig",    "text": "Rules engine: claim within warranty window, serial verified",              "status": "wip",
        "popup": { "type": "amplify", "msg": "Eligibility: PASS (0.4s)" } },
      { "from": "a-gw-elig",    "to": "a-route-agt",  "text": "Eligible → Smart Routing Agent selects repair station",                    "status": "ready" },
      { "from": "a-route-agt",  "to": "a-diag-agt",   "text": "Diagnostic Agent analyses fault code and service history",                 "status": "wip" },
      { "from": "a-diag-agt",   "to": "a-gw-fix",     "text": "Diagnosis: component failure — repairable",                                "status": "ready" },
      { "from": "a-gw-fix",     "to": "a-repair-sub", "text": "Claim routed to Repair Station (SLA: 1 business day)",                    "status": "wip" },
      { "from": "a-repair-sub", "to": "a-close-sys",  "text": "Repair complete — Closure & Audit System records outcome",                 "status": "ready" },
      { "from": "a-close-sys",  "to": "a-notify-agt", "text": "Audit passed — Notification Agent fires SMS + email with tracking",        "status": "ready",
        "popup": { "type": "amplify", "msg": "Claim closed in 2.5 days — CSAT score: 9.2/10" } }
    ]
  },

  "spec": {
    "dmaic": {
      "define":   "High defect rate (28%), long cycle time (18 days) in warranty claim processing — sourced from CSAT surveys and ops data",
      "measure":  "Baseline: 42% first-pass yield, 28% data-entry error rate, 18-day average cycle time, $210 cost per claim",
      "analyse":  "Root causes: unstructured phone intake, no real-time validation (poka-yoke absent), manual eligibility lookup with no SLA, ad-hoc routing with no skill-based assignment",
      "improve":  "Introduce: self-service portal with Poka-Yoke validation engine, Eligibility Rules System (automated), Smart Routing Agent, automated Repair/Replace stations with SLA enforcement",
      "control":  "After-phase stations enforce hard SLAs; Closure & Audit System logs every decision for continuous monitoring; control charts run weekly to detect drift"
    },
    "nodeInventory": [
      { "id": "b-call-in",    "type": "task",      "phase": "before", "waste": "motion",      "role": "Customer must call in or send email — creates wait and manual transcription" },
      { "id": "b-paper",      "type": "task",      "phase": "before", "waste": "defects",     "role": "Manually keyed paper form — 28% data entry error rate" },
      { "id": "b-manual-chk", "type": "task",      "phase": "before", "waste": "waiting",     "role": "Agent looks up eligibility in spreadsheet — 30-min average wait" },
      { "id": "b-route",      "type": "task",      "phase": "before", "waste": "motion",      "role": "Manual routing to team inbox — no skill-based assignment" },
      { "id": "b-diagnose",   "type": "task",      "phase": "before", "waste": "overprocessing","role": "Each technician re-diagnoses from scratch — no reuse of prior cases" },
      { "id": "b-repair",     "type": "task",      "phase": "before", "waste": "defects",     "role": "Manual repair without standardised work instructions — high re-open rate" },
      { "id": "b-replace",    "type": "task",      "phase": "before", "waste": "inventory",   "role": "Manual replacement pick — no ERP integration, shipping errors common" },

      { "id": "a-cust",       "type": "persona",   "phase": "after",  "leanTool": "5S / poka-yoke",   "role": "Named customer persona — structured portal eliminates intake waste" },
      { "id": "a-intake-agt", "type": "agent",     "phase": "after",  "leanTool": "poka-yoke",        "role": "Intake Station Agent orchestrates the poka-yoke validation loop" },
      { "id": "a-poka-yoke",  "type": "system",    "phase": "after",  "leanTool": "poka-yoke",        "role": "Mistake-proofing engine: 23 field rules enforced in real time, auto-prompts customer for corrections" },
      { "id": "a-fix-data",   "type": "agent",     "phase": "after",  "leanTool": "poka-yoke",        "role": "Auto-Fill Agent: pre-fills known data (serial, purchase date) and prompts for the rest" },
      { "id": "a-elig-sys",   "type": "system",    "phase": "after",  "leanTool": "standardised work","role": "Rules engine executes the same 12 eligibility checks every time in <0.5s" },
      { "id": "a-reject-agt", "type": "agent",     "phase": "after",  "leanTool": "jidoka",           "role": "Auto-Reject: generates rejection reason, logs for root-cause trending" },
      { "id": "a-route-agt",  "type": "agent",     "phase": "after",  "leanTool": "kanban / pull",    "role": "Smart Routing: assigns claim to next available qualified station using pull scheduling" },
      { "id": "a-diag-agt",   "type": "agent",     "phase": "after",  "leanTool": "standardised work","role": "Diagnostic Agent: matches fault code to knowledge base, eliminates re-diagnosis waste" },
      { "id": "a-repair-sub", "type": "subprocess","phase": "after",  "leanTool": "standardised work","role": "Repair Station: step-by-step torque & test instructions, 1-day SLA enforced" },
      { "id": "a-replace-sub","type": "subprocess","phase": "after",  "leanTool": "kanban",           "role": "Replacement Station: ERP-integrated pick, real-time stock check, courier booking" },
      { "id": "a-close-sys",  "type": "system",    "phase": "after",  "leanTool": "andon / control",  "role": "Closure & Audit System: records outcome, computes cycle time, feeds control charts" },
      { "id": "a-notify-agt", "type": "agent",     "phase": "after",  "leanTool": "5S",               "role": "Notification Agent: SMS + email with outcome and tracking — no phone call needed" }
    ],

    "wasteEliminated": [
      { "waste": "Defects",        "before": "28% data entry error rate",   "after": "~3% (poka-yoke prevented at source)" },
      { "waste": "Waiting",        "before": "30 min eligibility queue",    "after": "<1s automated rules check" },
      { "waste": "Motion",         "before": "Customer phone call + paper", "after": "Self-service portal" },
      { "waste": "Overprocessing", "before": "Re-diagnosis per technician", "after": "Knowledge-base lookup in Diagnostic Agent" },
      { "waste": "Inventory",      "before": "Manual part pick, no ERP",    "after": "Real-time ERP integration in Replacement Station" }
    ],

    "invariants": [
      "The Poka-Yoke engine must sit BEFORE the Eligibility gateway — data quality is gate 1",
      "The fix-data loop (a-fix-data → a-poka-yoke) must re-enter the validation engine, not skip it",
      "Repair and Replacement stations both converge into the same Closure & Audit System node",
      "No manual tasks (type=task) appear in the after phase — every step is agent, system, subprocess, gateway, or event",
      "Agent nodes appear only in the after phase — zero agents in the before phase"
    ]
  }
}
