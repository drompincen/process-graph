    { "label": "First-Pass %",  "before": "42%",      "after": "91%",      "positive": true  },
    { "label": "Automation",    "before": "0%",       "after": "85%",      "positive": true  },
    { "label": "Cost/Claim",    "before": "$210",     "after": "$28",      "positive": false }
  ],

