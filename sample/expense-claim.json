    { "id": "c11", "from": "photo-receipt",     "to": "digital-submit",   "type": "sequence",    "phase": ["phase1"] },
    { "id": "c12", "from": "digital-submit",   "to": "email-approval",   "type": "sequence",    "phase": ["phase1"] },
    { "id": "c13", "from": "email-approval",   "to": "mgr-email-review", "type": "message",     "phase": ["phase1"] },
    { "id": "c14", "from": "mgr-email-review", "to": "finance-process",  "type": "message",     "phase": ["phase1"], "label": "Approved" },
    { "id": "c15", "from": "mgr-email-review", "to": "end-rejected",     "type": "sequence",    "phase": ["phase1"], "label": "Rejected" },
    { "id": "c16", "from": "finance-process",  "to": "end-reimbursed",   "type": "sequence",    "phase": ["phase1"] },

    { "id": "c20", "from": "start",            "to": "photo-receipt",     "type": "sequence",    "phase": ["phase2"] },
    { "id": "c21", "from": "photo-receipt",     "to": "ocr-extract",      "type": "message",     "phase": ["phase2"] },
    { "id": "c22", "from": "ocr-extract",      "to": "policy-check",     "type": "sequence",    "phase": ["phase2"] },
    { "id": "c23", "from": "policy-check",     "to": "gateway-approve",  "type": "message",     "phase": ["phase2"] },
