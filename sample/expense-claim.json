    { "id": "c34", "from": "ai-gateway",       "to": "auto-reimburse",   "type": "sequence",    "phase": "phase3", "decision": "yes",  "label": "Low Risk" },
    { "id": "c35", "from": "ai-gateway",       "to": "mgr-escalation",   "type": "sequence",    "phase": "phase3", "decision": "no",   "label": "High Risk" },
    { "id": "c36", "from": "mgr-escalation",   "to": "auto-reimburse",   "type": "sequence",    "phase": "phase3" },
    { "id": "c37", "from": "auto-reimburse",   "to": "end-reimbursed",   "type": "sequence",    "phase": "phase3" },
    { "id": "c38", "from": "ai-gateway",       "to": "end-rejected-ai",  "type": "sequence",    "phase": "phase3", "decision": "escalate", "label": "Fraud" }
