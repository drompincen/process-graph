    "phase1": {
      "stepCount": 7,
      "cycleTimeDays": 14,
      "rejectionRate": "~9%",
      "lostReceiptRate": "~1%",
      "manualSteps": 5,
      "automationPct": 20,
      "costPerClaim": 30
    },
    "phase2": {
      "stepCount": 6,
      "cycleTimeDays": 5,
      "rejectionRate": "~5%",
      "lostReceiptRate": "0%",
      "manualSteps": 2,
      "automationPct": 65,
      "costPerClaim": 15
    },
    "phase3": {
      "stepCount": 4,
      "cycleTimeDays": 1,
      "rejectionRate": "~2%",
      "lostReceiptRate": "0%",
      "manualSteps": 0,
      "automationPct": 95,
      "costPerClaim": 4
    }
  },

  "lanes": [
    { "id": "employee", "label": "Employee",     "color": "#1e3a5f", "height": 130 },
    { "id": "manager",  "label": "Manager",      "color": "#1a3a2a", "height": 130 },
    { "id": "finance",  "label": "Finance",      "color": "#3a1a3a", "height": 130 },
    { "id": "system",   "label": "System",       "color": "#2a2a1a", "height": 130 }
  ],

  "nodes": [
    { "id": "start",             "type": "start-event", "label": "Expense\nIncurred",        "lane": "employee", "x": 100 },
    { "id": "collect-receipts",  "type": "task",        "label": "Collect Paper\nReceipts",   "lane": "employee", "x": 260, "phase": ["phase0"] },
    { "id": "fill-form",        "type": "task",        "label": "Fill Paper\nClaim Form",    "lane": "employee", "x": 420, "phase": ["phase0"] },
    { "id": "walk-to-mgr",      "type": "task",        "label": "Walk Form\nto Manager",     "lane": "employee", "x": 580, "phase": ["phase0"] },
    { "id": "paper-note",       "type": "annotation",  "label": "Lost receipts ~8%\n30-day SLA breach\ncommon",  "lane": "employee", "x": 260, "phase": ["phase0"] },

    { "id": "photo-receipt",    "type": "task",        "label": "Snap Receipt\n(Mobile App)", "lane": "employee", "x": 260, "phase": ["phase1", "phase2"] },
    { "id": "digital-submit",   "type": "task",        "label": "Digital\nSubmission",        "lane": "employee", "x": 420, "phase": ["phase1"] },
    { "id": "email-approval",   "type": "task",        "label": "Email\nApproval Request",    "lane": "employee", "x": 580, "phase": ["phase1"] },

    { "id": "ocr-extract",      "type": "subprocess",  "label": "OCR\nExtraction",           "lane": "system",   "x": 420, "phase": ["phase2"], "state": "automated" },
    { "id": "policy-check",     "type": "subprocess",  "label": "Auto Policy\nCheck",         "lane": "system",   "x": 580, "phase": ["phase2"], "state": "automated" },

    { "id": "ai-expense-agent", "type": "agent",       "label": "AI Expense\nAgent",          "lane": "system",   "x": 260, "phase": "phase3", "state": "automated" },
    { "id": "fraud-detect",     "type": "subprocess",  "label": "Fraud\nDetection",           "lane": "system",   "x": 420, "phase": "phase3", "state": "automated" },
    { "id": "realtime-policy",  "type": "system",      "label": "Real-Time\nPolicy Engine",   "lane": "system",   "x": 580, "phase": "phase3", "state": "automated" },

    { "id": "mgr-review",       "type": "task",        "label": "Manager\nReview",            "lane": "manager",  "x": 740, "phase": ["phase0"] },
    { "id": "mgr-email-review", "type": "task",        "label": "Manager\nEmail Review",      "lane": "manager",  "x": 740, "phase": ["phase1"] },

