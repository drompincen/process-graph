    { "id": "ai-gateway",       "type": "gateway",     "label": "Risk\nLevel?",               "lane": "system",   "x": 740, "phase": "phase3" },
    { "id": "mgr-escalation",   "type": "task",        "label": "Manager\nEscalation Only",    "lane": "manager",  "x": 900, "phase": "phase3" },

    { "id": "finance-manual",   "type": "task",        "label": "Manual Entry\ninto Ledger",   "lane": "finance",  "x": 900, "phase": ["phase0"] },
