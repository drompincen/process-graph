  "story": {
    "storyId": "expense-claim-transformation",
    "version": 1,
    "createdAt": "2026-01-15",
    "createdBy": "finance.ops@company.com",
    "problem": {
      "headline": "Expense reimbursements take 30 days with 12% rejection and 8% lost receipts",
      "description": "Employees collect paper receipts, fill forms by hand, and walk them to managers. Finance re-enters data manually into the ledger. Lost receipts, transcription errors, and 30-day cycle times are the norm.",
      "impactMetric": { "kpiId": "cycle-time", "value": 30, "unit": "days" },
      "evidence": [
        { "label": "Q4 Finance Audit", "url": "#", "addedAt": "2025-12-10", "addedBy": "cfo@company.com" },
        { "label": "Employee Satisfaction Survey (n=220)", "url": "#", "addedAt": "2026-01-05", "addedBy": "hr@company.com" }
      ],
      "scope": ["collect-receipts", "fill-form", "walk-to-mgr", "finance-manual"],
      "risks": [
        "Paper receipts lost before submission",
        "Manual transcription errors in spreadsheets",
        "No audit trail for rejected claims",
        "Finance team bottleneck -- 30-day SLA breach"
      ]
    },
    "vision": {
      "summary": "AI-powered expense agent delivers same-day reimbursement with zero manual steps",
      "description": "Replace paper receipts with <b>AI-powered capture</b>. Automate OCR, policy checks, and fraud detection. Manager reviews only high-risk exceptions. Auto-reimbursement within hours.",
      "kpiTargets": [
        { "kpiId": "cycle-time",   "min": 0.5, "max": 1,  "confidence": "high",   "horizon": "Q4 2026" },
        { "kpiId": "rejection-rate","min": 1,  "max": 3,  "confidence": "medium", "horizon": "Q4 2026" },
        { "kpiId": "lost-receipts","min": 0,   "max": 0,  "confidence": "high",   "horizon": "Q2 2026" }
      ],
      "acceptanceCriteria": [
        "Zero paper receipts in process",
        "OCR extracts receipt data with >98% accuracy",
        "Policy checks complete in under 2 seconds",
        "Fraud detection flags anomalies with <1% false positive rate",
        "Same-day reimbursement for 90%+ of claims"
      ]
    },
    "phases": [
      {
        "label": "Phase 0: Paper Receipts",
        "phaseRef": "phase0",
        "description": "Baseline manual process. Employees collect physical receipts, fill paper forms, walk them to managers. Manager signs off by hand. Finance manually enters into ledger. 30-day cycle.",
        "duration": "baseline"
      },
      {
        "label": "Phase 1: Mobile Capture",
        "phaseRef": "phase1",
        "description": "Replace paper receipts with <b>mobile photo capture</b>. Digital submission form replaces paper. Manager approves via email. Finance still processes manually but with digital input.",
        "duration": "6 weeks"
      },
      {
        "label": "Phase 2: OCR + Policy",
        "phaseRef": "phase2",
        "description": "Add <b>OCR extraction</b> to automatically read receipt data. <b>Policy engine</b> auto-checks category limits and per diem rules. Small amounts auto-approved via RPA. Manager reviews only exceptions.",
        "duration": "8 weeks"
      },
      {
        "label": "Phase 3: AI Agent",
        "phaseRef": "phase3",
        "description": "<b>AI expense agent</b> handles end-to-end processing. Real-time fraud detection scores every claim. Policy engine enforces all rules instantly. Auto-reimbursement for low-risk claims. Manager escalation only for high-risk anomalies.",
        "duration": "10 weeks"
      }
    ],
    "ideaCards": [
      {
        "id": "ic1",
        "title": "Mobile Receipt Capture",
        "phases": ["phase1"],
        "hypothesis": "Replacing paper receipts with <b>mobile photos</b> eliminates lost receipts and reduces submission friction from days to seconds.",
        "expectedKpiImpacts": [
          { "kpiId": "lost-receipts", "delta": -7, "confidence": "high" },
          { "kpiId": "cycle-time",    "delta": -16, "confidence": "medium" }
        ]
      },
      {
        "id": "ic2",
        "title": "OCR + Auto Policy Check",
        "phases": ["phase2"],
        "hypothesis": "OCR extraction plus automated policy checking removes manual data entry and catches violations <b>before</b> manager review, cutting cycle time by 60%.",
        "expectedKpiImpacts": [
          { "kpiId": "cycle-time",      "delta": -9, "confidence": "high" },
          { "kpiId": "rejection-rate",  "delta": -4, "confidence": "medium" }
        ]
      },
      {
        "id": "ic3",
        "title": "AI Expense Agent + Fraud Detection",
        "phases": ["phase3"],
        "hypothesis": "An <b>AI agent</b> with real-time fraud detection and auto-reimbursement eliminates all manual steps and delivers same-day payment for 95% of claims.",
        "expectedKpiImpacts": [
          { "kpiId": "cycle-time",      "delta": -4,  "confidence": "high" },
          { "kpiId": "rejection-rate",  "delta": -3,  "confidence": "medium" },
          { "kpiId": "cost-per-claim",  "delta": -11, "confidence": "high" }
        ]
      }
    ],
    "kpis": [
      { "id": "cycle-time",     "label": "Cycle Time",     "unit": "days", "direction": "lower_is_better", "baseline": 30,  "current": 30, "format": "0" },
      { "id": "rejection-rate", "label": "Rejection Rate",  "unit": "%",   "direction": "lower_is_better", "baseline": 12,  "current": 12, "format": "0" },
      { "id": "lost-receipts",  "label": "Lost Receipts",   "unit": "%",   "direction": "lower_is_better", "baseline": 8,   "current": 8,  "format": "0" },
      { "id": "cost-per-claim", "label": "Cost per Claim",  "unit": "$",   "direction": "lower_is_better", "baseline": 42,  "current": 42, "format": "0" }
    ],
    "benefits": [
      {
        "id": "b1", "title": "Eliminate Lost Receipts",   "phaseId": "phase1", "kpiId": "lost-receipts",
        "baseline": 8, "targetRange": { "min": 0, "max": 1 },
        "boundNodes": ["photo-receipt"], "realized": false
      },
      {
        "id": "b2", "title": "Automated Policy Checks",   "phaseId": "phase2", "kpiId": "cycle-time",
        "baseline": 14, "targetRange": { "min": 3, "max": 5 },
        "boundNodes": ["ocr-extract", "policy-check", "rpa-payment"], "realized": false
      },
      {
        "id": "b3", "title": "Same-Day Reimbursement",    "phaseId": "phase3", "kpiId": "cycle-time",
        "baseline": 5, "targetRange": { "min": 0.5, "max": 1 },
        "boundNodes": ["ai-expense-agent", "fraud-detect", "auto-reimburse"], "realized": false
      }
    ],
    "uiHints": {
      "initialView": "split",
      "initialPhase": "phase1"
    }
  },

  "spec": {
    "schemaVersion": "2.0",
    "description": "4-phase progressive transformation of employee expense claims: paper receipts (phase0) to mobile capture (phase1) to OCR + policy engine (phase2) to AI expense agent with fraud detection (phase3).",
    "nodeInventory": [
      { "id": "start",             "type": "start-event", "lane": "employee", "phase": null,              "role": "Triggers the expense claim process -- present in all phases",                              "critical": true  },
      { "id": "collect-receipts",  "type": "task",        "lane": "employee", "phase": ["phase0"],        "role": "Employee collects and stores paper receipts -- high loss risk (~8%)",                      "critical": true  },
      { "id": "fill-form",        "type": "task",        "lane": "employee", "phase": ["phase0"],        "role": "Employee manually transcribes receipts onto paper claim form -- error-prone",              "critical": true  },
      { "id": "walk-to-mgr",      "type": "task",        "lane": "employee", "phase": ["phase0"],        "role": "Employee physically delivers form to manager -- untracked handoff",                       "critical": true  },
      { "id": "paper-note",       "type": "annotation",  "lane": "employee", "phase": ["phase0"],        "role": "Documents lost receipt risk and 30-day SLA breach pain points",                           "critical": false },
      { "id": "photo-receipt",    "type": "task",        "lane": "employee", "phase": "phase1",          "role": "Employee photographs receipt via mobile app -- zero paper, instant capture",              "critical": true  },
      { "id": "digital-submit",   "type": "task",        "lane": "employee", "phase": ["phase1"],        "role": "Employee submits digital form with photo attachment",                                     "critical": true  },
      { "id": "email-approval",   "type": "task",        "lane": "employee", "phase": ["phase1"],        "role": "System sends email to manager requesting approval",                                      "critical": true  },
      { "id": "ocr-extract",      "type": "subprocess",  "lane": "system",   "phase": "phase2",          "role": "OCR extracts structured data from receipt photo -- amount, date, vendor, VAT",            "critical": true  },
      { "id": "policy-check",     "type": "subprocess",  "lane": "system",   "phase": "phase2",          "role": "Automated policy engine checks category limits, per diem rules, duplicates",              "critical": true  },
      { "id": "ai-expense-agent", "type": "agent",       "lane": "system",   "phase": "phase3",          "role": "AI agent handles end-to-end receipt parsing, categorization, and submission",             "critical": true  },
      { "id": "fraud-detect",     "type": "subprocess",  "lane": "system",   "phase": "phase3",          "role": "ML-based fraud detection scores anomaly risk for every claim",                            "critical": true  },
      { "id": "realtime-policy",  "type": "system",      "lane": "system",   "phase": "phase3",          "role": "Real-time policy enforcement engine with dynamic rule updates",                           "critical": true  },
      { "id": "mgr-review",       "type": "task",        "lane": "manager",  "phase": ["phase0", "phase1"], "role": "Manager manually reviews claim and signs off -- bottleneck in early phases",           "critical": true  },
      { "id": "mgr-email-review", "type": "task",        "lane": "manager",  "phase": ["phase1"],        "role": "Manager reviews and approves claim via email reply",                                     "critical": true  },
