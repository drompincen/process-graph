    { "id": "phase1", "label": "1 -- Mobile Capture",   "color": "#3b82f6" },
    { "id": "phase2", "label": "2 -- OCR + Policy",     "color": "#8b5cf6" },
    { "id": "phase3", "label": "3 -- AI Agent",         "color": "#10b981" }
  ],

  "metrics": {
