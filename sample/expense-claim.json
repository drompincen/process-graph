    { "id": "c25", "from": "gateway-approve",  "to": "mgr-exception",    "type": "sequence",    "phase": ["phase2"],   "decision": "no",  "label": "Review" },
    { "id": "c26", "from": "mgr-exception",    "to": "rpa-payment",      "type": "sequence",    "phase": ["phase2"] },
    { "id": "c27", "from": "rpa-payment",      "to": "end-reimbursed",   "type": "sequence",    "phase": ["phase2"] },
    { "id": "c28", "from": "gateway-approve",  "to": "end-rejected-sys", "type": "sequence",    "phase": ["phase2"],   "decision": "escalate", "label": "Rejected" },

    { "id": "c30", "from": "start",            "to": "ai-expense-agent", "type": "sequence",    "phase": "phase3" },
    { "id": "c31", "from": "ai-expense-agent", "to": "fraud-detect",     "type": "sequence",    "phase": "phase3" },
    { "id": "c32", "from": "fraud-detect",     "to": "realtime-policy",  "type": "sequence",    "phase": "phase3" },
