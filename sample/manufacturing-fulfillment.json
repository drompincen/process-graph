    { "id": "b-inv",      "type": "task",              "label": "Spreadsheet\nInventory Check","lane": "warehouse",  "x": 530,  "phase": "before", "diff": "removed" },
    { "id": "b-gw-inv",   "type": "gateway",           "label": "In Stock?",                  "lane": "warehouse",  "x": 670,  "phase": "before" },
    { "id": "b-procure",  "type": "task",              "label": "Manual\nProcurement",         "lane": "warehouse",  "x": 810,  "phase": "before" },
    { "id": "b-wait",     "type": "intermediate-event","label": "Wait for\nParts (5-7 days)",  "lane": "warehouse",  "x": 950,  "phase": "before" },
    { "id": "b-assemble", "type": "task",              "label": "Ad-hoc\nAssembly",            "lane": "production", "x": 950,  "phase": "before", "diff": "removed" },
    { "id": "b-qc",       "type": "task",              "label": "Manual QC\nInspection",       "lane": "production", "x": 1090, "phase": "before", "diff": "removed" },
    { "id": "b-gw-qc",   "type": "gateway",           "label": "QC Pass?",                   "lane": "production", "x": 1230, "phase": "before" },
    { "id": "b-rework",   "type": "task",              "label": "Rework\n& Repeat",            "lane": "production", "x": 1370, "phase": "before", "diff": "removed" },
    { "id": "b-ship",     "type": "task",              "label": "Manual Pack\n& Ship",         "lane": "warehouse",  "x": 1230, "phase": "before", "diff": "removed" },
    { "id": "b-notify",   "type": "task",              "label": "Phone Call\nNotification",    "lane": "ops",        "x": 1370, "phase": "before", "diff": "removed" },
    { "id": "b-end",      "type": "end-event",         "label": "Delivered",                  "lane": "customer",   "x": 1510, "phase": "before" },
    { "id": "a-start",    "type": "start-event", "label": "Order\nReceived",              "lane": "customer",   "x": 110,  "phase": "after" },
    { "id": "a-cust",     "type": "persona",     "label": "Customer\nSelf-Service\nPortal","lane": "customer",  "x": 250,  "phase": "after", "diff": "added" },
    { "id": "a-validate", "type": "agent",       "label": "Order\nValidation\nAgent",     "lane": "ops",        "x": 390,  "phase": "after", "diff": "added" },
    { "id": "a-inv-sys",  "type": "system",      "label": "Inventory\nManagement\nSystem","lane": "warehouse",  "x": 530,  "phase": "after", "diff": "added" },
    { "id": "a-gw-inv",   "type": "gateway",     "label": "In Stock?",                   "lane": "warehouse",  "x": 670,  "phase": "after" },
    { "id": "a-proc",     "type": "agent",       "label": "Auto-Procurement\nAgent",      "lane": "warehouse",  "x": 810,  "phase": "after", "diff": "added" },
    { "id": "a-line1",    "type": "subprocess",  "label": "Assembly Line\nStep 1: Prep",  "lane": "production", "x": 810,  "phase": "after", "diff": "added", "state": "automated" },
    { "id": "a-line2",    "type": "subprocess",  "label": "Assembly Line\nStep 2: Build", "lane": "production", "x": 950,  "phase": "after", "diff": "added", "state": "automated" },
    { "id": "a-line3",    "type": "subprocess",  "label": "Assembly Line\nStep 3: Test",  "lane": "production", "x": 1090, "phase": "after", "diff": "added", "state": "automated" },
    { "id": "a-qa",       "type": "agent",       "label": "QA Automation\nAgent",         "lane": "production", "x": 1230, "phase": "after", "diff": "added" },
    { "id": "a-gw-qc",   "type": "gateway",     "label": "QC Pass?",                    "lane": "production", "x": 1370, "phase": "after" },
    { "id": "a-ship-sys", "type": "system",      "label": "Shipping &\nLogistics API",    "lane": "warehouse",  "x": 1370, "phase": "after", "diff": "added" },
    { "id": "a-notify",   "type": "agent",       "label": "Notification\nAgent",          "lane": "ops",        "x": 1510, "phase": "after", "diff": "added" },
    { "id": "a-end",      "type": "end-event",   "label": "Delivered",                   "lane": "customer",   "x": 1650, "phase": "after" }
  ],
  "connections": [
    { "id": "b-c1",  "from": "b-start",    "to": "b-intake",   "type": "sequence", "phase": "before" },
    { "id": "b-c2",  "from": "b-intake",   "to": "b-approve",  "type": "sequence", "phase": "before" },
    { "id": "b-c3",  "from": "b-approve",  "to": "b-inv",      "type": "message",  "phase": "before" },
    { "id": "b-c4",  "from": "b-inv",      "to": "b-gw-inv",   "type": "sequence", "phase": "before" },
    { "id": "b-c5",  "from": "b-gw-inv",   "to": "b-procure",  "type": "sequence", "phase": "before", "decision": "no",  "label": "No" },
    { "id": "b-c6",  "from": "b-gw-inv",   "to": "b-assemble", "type": "sequence", "phase": "before", "decision": "yes", "label": "Yes" },
    { "id": "b-c7",  "from": "b-procure",  "to": "b-wait",     "type": "sequence", "phase": "before" },
    { "id": "b-c8",  "from": "b-wait",     "to": "b-assemble", "type": "sequence", "phase": "before" },
    { "id": "b-c9",  "from": "b-assemble", "to": "b-qc",       "type": "sequence", "phase": "before" },
    { "id": "b-c10", "from": "b-qc",       "to": "b-gw-qc",   "type": "sequence", "phase": "before" },
    { "id": "b-c11", "from": "b-gw-qc",   "to": "b-rework",   "type": "sequence", "phase": "before", "decision": "no",  "label": "Fail" },
    { "id": "b-c12", "from": "b-gw-qc",   "to": "b-ship",     "type": "sequence", "phase": "before", "decision": "yes", "label": "Pass" },
    { "id": "b-c13", "from": "b-rework",   "to": "b-assemble", "type": "sequence", "phase": "before" },
    { "id": "b-c14", "from": "b-ship",     "to": "b-notify",   "type": "sequence", "phase": "before" },
    { "id": "b-c15", "from": "b-notify",   "to": "b-end",      "type": "sequence", "phase": "before" },
    { "id": "a-c1",  "from": "a-start",    "to": "a-cust",     "type": "sequence", "phase": "after" },
    { "id": "a-c2",  "from": "a-cust",     "to": "a-validate", "type": "message",  "phase": "after" },
    { "id": "a-c3",  "from": "a-validate", "to": "a-inv-sys",  "type": "message",  "phase": "after" },
    { "id": "a-c4",  "from": "a-inv-sys",  "to": "a-gw-inv",   "type": "sequence", "phase": "after" },
    { "id": "a-c5",  "from": "a-gw-inv",   "to": "a-proc",     "type": "sequence", "phase": "after", "decision": "no",  "label": "No"  },
    { "id": "a-c6",  "from": "a-gw-inv",   "to": "a-line1",    "type": "sequence", "phase": "after", "decision": "yes", "label": "Yes" },
    { "id": "a-c7",  "from": "a-proc",     "to": "a-line1",    "type": "message",  "phase": "after" },
    { "id": "a-c8",  "from": "a-line1",    "to": "a-line2",    "type": "sequence", "phase": "after" },
    { "id": "a-c9",  "from": "a-line2",    "to": "a-line3",    "type": "sequence", "phase": "after" },
    { "id": "a-c10", "from": "a-line3",    "to": "a-qa",       "type": "message",  "phase": "after" },
    { "id": "a-c11", "from": "a-qa",       "to": "a-gw-qc",   "type": "sequence", "phase": "after" },
    { "id": "a-c12", "from": "a-gw-qc",   "to": "a-ship-sys", "type": "message",  "phase": "after", "decision": "yes", "label": "Pass" },
    { "id": "a-c13", "from": "a-gw-qc",   "to": "a-line2",    "type": "sequence", "phase": "after", "decision": "no",  "label": "Fail" },
    { "id": "a-c14", "from": "a-ship-sys", "to": "a-notify",   "type": "message",  "phase": "after" },
    { "id": "a-c15", "from": "a-notify",   "to": "a-end",      "type": "sequence", "phase": "after" }
  ],
  "story": {
    "title": "Happy Path: Agent-Powered Order",
    "description": "An order arrives via the customer portal. The Validation Agent clears it instantly. Inventory checks out, the three-step assembly line runs in sequence, QA automation passes, and the order ships — all within hours rather than weeks.",
    "sequence": [
      { "from": "a-start",    "to": "a-cust",     "text": "Customer opens the self-service portal",                       "status": "ready"  },
      { "from": "a-cust",     "to": "a-validate", "text": "Portal submits structured order — no manual data entry",       "status": "ready"  },
      { "from": "a-validate", "to": "a-inv-sys",  "text": "Validation Agent checks rules and triggers inventory query",   "status": "wip",
        "popup": { "type": "amplify", "msg": "All 14 validation rules passed in 0.3s" } },
      { "from": "a-inv-sys",  "to": "a-gw-inv",   "text": "Inventory System: 47 units in stock — no procurement needed", "status": "ready"  },
      { "from": "a-gw-inv",   "to": "a-line1",    "text": "Stock confirmed — assembly line released immediately",         "status": "ready"  },
      { "from": "a-line1",    "to": "a-line2",    "text": "Step 1 Prep: jig loaded, materials staged (8 min)",            "status": "wip",
        "popup": { "type": "amplify", "msg": "Prep complete — zero idle wait" } },
      { "from": "a-line2",    "to": "a-line3",    "text": "Step 2 Build: components assembled to spec (22 min)",          "status": "wip"    },
      { "from": "a-line3",    "to": "a-qa",       "text": "Step 3 Test: functional tests passed, ready for QA",           "status": "wip"    },
      { "from": "a-qa",       "to": "a-gw-qc",   "text": "QA Agent runs 200-point automated check (4 min)",              "status": "wip",
        "popup": { "type": "amplify", "msg": "200 / 200 checks passed" } },
      { "from": "a-gw-qc",   "to": "a-ship-sys", "text": "QC result: PASS — shipment authorised automatically",          "status": "ready"  },
      { "from": "a-ship-sys", "to": "a-notify",   "text": "Logistics API books carrier and prints label",                  "status": "wip"    },
      { "from": "a-notify",   "to": "a-end",      "text": "Customer receives real-time tracking link via email + SMS",    "status": "ready"  }
    ]
  },
  "spec": {
    "nodeInventory": [
      { "id": "b-start",    "type": "start-event",       "lane": "customer",   "phase": "before", "role": "Process trigger — order received by phone or email" },
      { "id": "b-intake",   "type": "task",              "lane": "ops",        "phase": "before", "role": "Sales rep manually copies order details into spreadsheet", "critical": true },
      { "id": "b-approve",  "type": "task",              "lane": "ops",        "phase": "before", "role": "Manager eyeballs spreadsheet and emails approval", "critical": false },
      { "id": "b-inv",      "type": "task",              "lane": "warehouse",  "phase": "before", "role": "Warehouse staff count stock manually — error-prone", "critical": true },
      { "id": "b-gw-inv",   "type": "gateway",           "lane": "warehouse",  "phase": "before", "role": "Split: sufficient stock vs. need to order parts" },
      { "id": "b-procure",  "type": "task",              "lane": "warehouse",  "phase": "before", "role": "Ops emails or calls suppliers — no SLA, no tracking" },
      { "id": "b-wait",     "type": "intermediate-event","lane": "warehouse",  "phase": "before", "role": "Order sits idle waiting for parts (5-7 business days average)" },
      { "id": "b-assemble", "type": "task",              "lane": "production", "phase": "before", "role": "Floor workers assemble without standardised steps or jig", "critical": true },
      { "id": "b-qc",       "type": "task",              "lane": "production", "phase": "before", "role": "Inspector visually checks finished unit — inconsistent criteria" },
      { "id": "b-gw-qc",   "type": "gateway",           "lane": "production", "phase": "before", "role": "40% of units fail QC and loop back to rework" },
      { "id": "b-rework",   "type": "task",              "lane": "production", "phase": "before", "role": "Disassemble, fix, reassemble — adds 1-3 days per cycle", "critical": true },
      { "id": "b-ship",     "type": "task",              "lane": "warehouse",  "phase": "before", "role": "Manual packing with no carrier integration — booking errors common" },
      { "id": "b-notify",   "type": "task",              "lane": "ops",        "phase": "before", "role": "Sales rep calls customer — no tracking data available" },
      { "id": "b-end",      "type": "end-event",         "lane": "customer",   "phase": "before", "role": "Order delivered — average 3-4 weeks from receipt" },
      { "id": "a-start",    "type": "start-event",  "lane": "customer",   "phase": "after", "role": "Process trigger — structured order from portal", "critical": true },
      { "id": "a-cust",     "type": "persona",       "lane": "customer",   "phase": "after", "role": "Named customer persona using self-service portal — zero phone/email" },
      { "id": "a-validate", "type": "agent",         "lane": "ops",        "phase": "after", "role": "AI agent: validates 14 business rules in <1s, flags anomalies", "critical": true },
      { "id": "a-inv-sys",  "type": "system",        "lane": "warehouse",  "phase": "after", "role": "ERP inventory system: real-time stock query, no human lookup", "critical": true },
      { "id": "a-gw-inv",   "type": "gateway",       "lane": "warehouse",  "phase": "after", "role": "Split: in stock (immediate) vs. needs parts (auto-procurement)" },
      { "id": "a-proc",     "type": "agent",         "lane": "warehouse",  "phase": "after", "role": "Procurement agent: auto-raises PO, tracks lead time, alerts on delays" },
      { "id": "a-line1",    "type": "subprocess",    "lane": "production", "phase": "after", "role": "Assembly line stage 1: standardised prep with jig setup (8 min SLA)", "critical": true },
      { "id": "a-line2",    "type": "subprocess",    "lane": "production", "phase": "after", "role": "Assembly line stage 2: core build, torque-controlled tooling (22 min SLA)", "critical": true },
      { "id": "a-line3",    "type": "subprocess",    "lane": "production", "phase": "after", "role": "Assembly line stage 3: functional test, burn-in, burn-out (12 min SLA)", "critical": true },
      { "id": "a-qa",       "type": "agent",         "lane": "production", "phase": "after", "role": "QA agent: 200-point automated check, vision inspection, <5s per unit", "critical": true },
      { "id": "a-gw-qc",   "type": "gateway",       "lane": "production", "phase": "after", "role": "Split: QC pass (ship) vs. fail (loop back to stage 2 only)" },
      { "id": "a-ship-sys", "type": "system",        "lane": "warehouse",  "phase": "after", "role": "Logistics API: books carrier, prints label, sends tracking — no human" },
      { "id": "a-notify",   "type": "agent",         "lane": "ops",        "phase": "after", "role": "Notification agent: SMS + email with live tracking link sent on dispatch" },
      { "id": "a-end",      "type": "end-event",     "lane": "customer",   "phase": "after", "role": "Order delivered — 3-5 days from receipt, fully traceable" }
    ],
    "connectionInventory": [
      { "id": "b-c1",  "from": "b-start",    "to": "b-intake",   "semantics": "Inbound order triggers manual data entry" },
      { "id": "b-c2",  "from": "b-intake",   "to": "b-approve",  "semantics": "Spreadsheet handed to manager for review" },
      { "id": "b-c3",  "from": "b-approve",  "to": "b-inv",      "semantics": "Approval email forwarded to warehouse" },
      { "id": "b-c4",  "from": "b-inv",      "to": "b-gw-inv",   "semantics": "Manual count result drives stock decision" },
      { "id": "b-c5",  "from": "b-gw-inv",   "to": "b-procure",  "semantics": "Parts missing — manual procurement triggered", "conditions": "Stock count < required quantity" },
      { "id": "b-c6",  "from": "b-gw-inv",   "to": "b-assemble", "semantics": "Parts available — assembly starts immediately", "conditions": "Stock count >= required quantity" },
      { "id": "b-c7",  "from": "b-procure",  "to": "b-wait",     "semantics": "PO raised — now waiting on supplier delivery" },
      { "id": "b-c8",  "from": "b-wait",     "to": "b-assemble", "semantics": "Parts arrived — assembly can finally begin" },
      { "id": "b-c9",  "from": "b-assemble", "to": "b-qc",       "semantics": "Finished unit passed to QC inspector" },
      { "id": "b-c10", "from": "b-qc",       "to": "b-gw-qc",   "semantics": "Inspector's pass/fail decision recorded" },
      { "id": "b-c11", "from": "b-gw-qc",   "to": "b-rework",   "semantics": "Unit failed — sent back for rework (40% rate)", "conditions": "Visual inspection finds defect" },
      { "id": "b-c12", "from": "b-gw-qc",   "to": "b-ship",     "semantics": "Unit passed QC — moved to packing area", "conditions": "Inspector approves unit" },
      { "id": "b-c13", "from": "b-rework",   "to": "b-assemble", "semantics": "Reworked unit returns to assembly — full re-check required" },
      { "id": "b-c14", "from": "b-ship",     "to": "b-notify",   "semantics": "Shipment dispatched — ops calls the customer" },
      { "id": "b-c15", "from": "b-notify",   "to": "b-end",      "semantics": "Order complete — no tracking visibility for customer" },
      { "id": "a-c1",  "from": "a-start",    "to": "a-cust",     "semantics": "Structured order form triggers the persona node" },
      { "id": "a-c2",  "from": "a-cust",     "to": "a-validate", "semantics": "Portal submits validated JSON payload to Validation Agent" },
      { "id": "a-c3",  "from": "a-validate", "to": "a-inv-sys",  "semantics": "Agent queries Inventory System via API after passing rules" },
      { "id": "a-c4",  "from": "a-inv-sys",  "to": "a-gw-inv",   "semantics": "Real-time stock level drives gateway decision" },
      { "id": "a-c5",  "from": "a-gw-inv",   "to": "a-proc",     "semantics": "Parts needed — Procurement Agent auto-raises PO", "conditions": "ERP stock < BOM quantity" },
      { "id": "a-c6",  "from": "a-gw-inv",   "to": "a-line1",    "semantics": "Stock confirmed — assembly line released at once", "conditions": "ERP stock >= BOM quantity" },
      { "id": "a-c7",  "from": "a-proc",     "to": "a-line1",    "semantics": "Parts confirmed inbound — assembly line pre-staged by agent" },
      { "id": "a-c8",  "from": "a-line1",    "to": "a-line2",    "semantics": "Stage 1 (Prep) completed to SLA — stage 2 starts immediately" },
      { "id": "a-c9",  "from": "a-line2",    "to": "a-line3",    "semantics": "Stage 2 (Build) completed to SLA — stage 3 starts immediately" },
      { "id": "a-c10", "from": "a-line3",    "to": "a-qa",       "semantics": "Stage 3 (Test) done — unit queued for automated QA" },
      { "id": "a-c11", "from": "a-qa",       "to": "a-gw-qc",   "semantics": "QA Agent result (pass/fail + failure code) sent to gateway" },
      { "id": "a-c12", "from": "a-gw-qc",   "to": "a-ship-sys", "semantics": "QC passed — Logistics API books carrier and prints label", "conditions": "All 200 QA checks pass" },
      { "id": "a-c13", "from": "a-gw-qc",   "to": "a-line2",    "semantics": "QC failed — unit returns to Stage 2 only (targeted rework)", "conditions": "One or more QA checks fail; failure code routes to correct stage" },
      { "id": "a-c14", "from": "a-ship-sys", "to": "a-notify",   "semantics": "Carrier confirmed — Notification Agent fires email + SMS" },
      { "id": "a-c15", "from": "a-notify",   "to": "a-end",      "semantics": "Customer has live tracking link — order complete" }
    ],
    "behaviors": [
      {
        "id": "beh-overlap",
        "trigger": "User drags any node in edit mode onto an occupied position",
        "expected": "Node snaps to nearest free 20px grid cell — no two nodes occupy the same cell",
        "involvedNodes": ["b-assemble", "b-qc", "a-line1", "a-line2", "a-line3"],
        "testRef": "J14-S5"
      },
      {
        "id": "beh-assembly-sequence",
        "trigger": "Simulation runs the after-phase happy path",
        "expected": "Token travels a-line1 → a-line2 → a-line3 in order with no skips",
        "involvedNodes": ["a-line1", "a-line2", "a-line3"],
        "testRef": "J16-assembly"
      },
      {
        "id": "beh-rework-loop",
        "trigger": "Simulation triggers the before-phase QC fail branch",
        "expected": "Token loops from b-gw-qc → b-rework → b-assemble",
        "involvedNodes": ["b-gw-qc", "b-rework", "b-assemble"],
        "testRef": "J16-rework"
      },
      {
        "id": "beh-agent-types",
        "trigger": "Diagram renders the after phase",
        "expected": "a-validate, a-proc, a-qa, a-notify render as chamfered-octagon agent nodes; a-inv-sys and a-ship-sys render as sharp-rect system nodes; a-cust renders as rounded-rect persona node",
        "involvedNodes": ["a-validate", "a-proc", "a-qa", "a-notify", "a-inv-sys", "a-ship-sys", "a-cust"],
        "testRef": "J15-S6"
      }
    ],
    "invariants": [
      "Every before-phase node marked diff=removed must have a functional replacement in the after phase",
      "No two nodes in the same lane and same phase may share the same x-coordinate",
      "The after phase must contain exactly 3 assembly-line subprocess nodes (a-line1, a-line2, a-line3) in sequence",
      "Agent nodes (type=agent) must appear in the after phase only — the before phase has zero agent nodes",
      "System nodes (type=system) must appear in the after phase only — the before phase has zero system nodes",
