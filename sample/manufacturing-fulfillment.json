  "story": {
    "title": "Happy Path: AI-Agent-Powered Order",
    "description": "An order arrives via the self-service portal. The Validation Agent clears it instantly. Inventory checks out, the three-step assembly line runs in sequence, QA automation passes, smart routing picks the optimal carrier, and the customer gets a real-time tracking link -- all within days rather than weeks.",
    "phases": [
      {
        "label": "Phase 0: Manual Assembly",
        "phaseRef": "phase0",
        "description": "Paper-based inventory, manual procurement via phone/email, ad-hoc assembly with no standardised steps, and visual QC inspection with a 40% rework rate. Lead time averages 3-4 weeks.",
        "duration": "baseline"
      },
      {
        "label": "Phase 1: Inventory System",
        "phaseRef": "phase1",
        "description": "Replace spreadsheet inventory with a <b>digital inventory management system</b>. Automated low-stock alerts replace manual counting. Basic order portal replaces phone/email intake. Assembly and QC remain manual but gain a digital checklist.",
        "duration": "8 weeks"
      },
      {
        "label": "Phase 2: Assembly Automation",
        "phaseRef": "phase2",
        "description": "Introduce a <b>3-step automated assembly line</b> (Prep, Build, Test). Digital QC checklist replaced by inline test stage. Automated procurement and shipping via logistics API. Rework targets build stage only.",
        "duration": "12 weeks"
      },
      {
        "label": "Phase 3: AI Agents",
        "phaseRef": "phase3",
        "description": "Deploy <b>AI agents</b> across the entire process: Validation Agent for order intake, Procurement Agent with predictive maintenance, QA Automation Agent with 200-point checks, and Smart Routing Agent for carrier selection. Notification Agent sends real-time tracking.",
        "duration": "10 weeks"
      }
    ],
    "sequence": [
      { "from": "start",          "to": "self-service",   "text": "Customer opens the self-service portal",                       "status": "ready"  },
      { "from": "self-service",   "to": "validate-agent", "text": "Portal submits structured order -- no manual data entry",      "status": "ready"  },
      { "from": "validate-agent", "to": "inv-system",     "text": "Validation Agent checks rules and triggers inventory query",   "status": "wip",
        "popup": { "type": "amplify", "msg": "All 14 validation rules passed in 0.3s" } },
      { "from": "inv-system",     "to": "gw-stock",       "text": "Inventory System: 47 units in stock -- no procurement needed", "status": "ready"  },
      { "from": "gw-stock",       "to": "line-prep",      "text": "Stock confirmed -- assembly line released immediately",        "status": "ready"  },
      { "from": "line-prep",      "to": "line-build",     "text": "Step 1 Prep: jig loaded, materials staged (8 min)",            "status": "wip",
        "popup": { "type": "amplify", "msg": "Prep complete -- zero idle wait" } },
      { "from": "line-build",     "to": "line-test",      "text": "Step 2 Build: components assembled to spec (22 min)",          "status": "wip"    },
      { "from": "line-test",      "to": "qa-agent",       "text": "Step 3 Test: functional tests passed, ready for QA",           "status": "wip"    },
      { "from": "qa-agent",       "to": "gw-qc-ai",      "text": "QA Agent runs 200-point automated check (4 min)",              "status": "wip",
        "popup": { "type": "amplify", "msg": "200 / 200 checks passed" } },
      { "from": "gw-qc-ai",      "to": "smart-route",    "text": "QC result: PASS -- smart routing engaged",                     "status": "ready"  },
      { "from": "smart-route",    "to": "notify-agent",   "text": "Smart Routing Agent selects optimal carrier and prints label", "status": "wip"    },
      { "from": "notify-agent",   "to": "end-ai",         "text": "Customer receives real-time tracking link via email + SMS",    "status": "ready"  }
    ]
  },

  "spec": {
    "schemaVersion": "2.0",
    "description": "4-phase progressive transformation of a manufacturing order fulfillment process: from manual assembly (phase0) through inventory digitisation (phase1), assembly line automation (phase2), to full AI-agent orchestration (phase3).",
    "nodeInventory": [
      { "id": "start",          "type": "start-event",        "lane": "customer",   "role": "Process trigger -- order received from customer (all phases)" },
      { "id": "phone-intake",   "type": "task",               "lane": "ops",        "phase": ["phase0"],           "role": "Sales rep manually copies order details into spreadsheet from phone/email", "critical": true },
      { "id": "mgr-approve",    "type": "task",               "lane": "ops",        "phase": ["phase0"],           "role": "Manager eyeballs spreadsheet and emails approval" },
      { "id": "note-manual",    "type": "annotation",         "lane": "ops",        "phase": ["phase0"],           "role": "Documents baseline pain points: 3-4 week lead time, 40% rework, zero automation" },
      { "id": "portal-order",   "type": "task",               "lane": "customer",   "phase": ["phase1", "phase2"], "role": "Customer submits structured order via web portal -- replaces phone/email" },
      { "id": "order-validate", "type": "task",               "lane": "ops",        "phase": ["phase1", "phase2"], "role": "Ops validates order against business rules manually then with checklist" },
      { "id": "self-service",   "type": "persona",            "lane": "customer",   "phase": "phase3",             "role": "Named customer persona using self-service portal -- zero phone/email" },
      { "id": "validate-agent", "type": "agent",              "lane": "ops",        "phase": "phase3",             "role": "AI agent: validates 14 business rules in <1s, flags anomalies", "critical": true },
      { "id": "sheet-inv",      "type": "task",               "lane": "warehouse",  "phase": ["phase0"],           "role": "Warehouse staff count stock from spreadsheet -- error-prone", "critical": true },
      { "id": "inv-system",     "type": "system",             "lane": "warehouse",  "phase": "phase1",             "role": "ERP inventory system: real-time stock query, automated alerts", "critical": true },
      { "id": "gw-stock",       "type": "gateway",            "lane": "warehouse",                                 "role": "Split: sufficient stock vs. need to order parts (all phases)" },
      { "id": "manual-procure", "type": "task",               "lane": "warehouse",  "phase": ["phase0", "phase1"], "role": "Ops emails or calls suppliers -- no SLA, no tracking" },
      { "id": "auto-procure",   "type": "task",               "lane": "warehouse",  "phase": ["phase2"],           "role": "Automated PO generation via supplier integration", "critical": true },
      { "id": "procure-agent",  "type": "agent",              "lane": "warehouse",  "phase": "phase3",             "role": "AI Procurement Agent: auto-raises PO, tracks lead time, alerts on delays" },
      { "id": "wait-parts",     "type": "intermediate-event", "lane": "warehouse",  "phase": ["phase0"],           "role": "Order sits idle waiting for parts (5-7 business days average)" },
      { "id": "stock-alert",    "type": "intermediate-event", "lane": "warehouse",  "phase": ["phase1", "phase2"], "role": "System sends low-stock alert and tracks inbound parts" },
      { "id": "predict-maint",  "type": "agent",              "lane": "warehouse",  "phase": "phase3",             "role": "Predictive Maintenance Agent: forecasts demand and pre-orders parts" },
      { "id": "adhoc-assembly", "type": "task",               "lane": "production", "phase": ["phase0", "phase1"], "role": "Floor workers assemble without standardised steps or jig", "critical": true },
      { "id": "line-prep",      "type": "subprocess",         "lane": "production", "phase": "phase2",             "role": "Assembly line stage 1: standardised prep with jig setup (8 min SLA)", "critical": true },
      { "id": "line-build",     "type": "subprocess",         "lane": "production", "phase": "phase2",             "role": "Assembly line stage 2: core build, torque-controlled tooling (22 min SLA)", "critical": true },
      { "id": "line-test",      "type": "subprocess",         "lane": "production", "phase": "phase2",             "role": "Assembly line stage 3: functional test, burn-in (12 min SLA)", "critical": true },
      { "id": "manual-qc",      "type": "task",               "lane": "production", "phase": ["phase0"],           "role": "Inspector visually checks finished unit -- inconsistent criteria" },
      { "id": "qc-checklist",   "type": "task",               "lane": "production", "phase": ["phase1"],           "role": "Digital QC checklist with pass/fail criteria -- still manual inspection" },
      { "id": "qa-agent",       "type": "agent",              "lane": "production", "phase": "phase3",             "role": "QA Agent: 200-point automated check, vision inspection, <5s per unit", "critical": true },
