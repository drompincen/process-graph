{
  "title": "Manufacturing Order Fulfillment",
  "subtitle": "From manual chaos to agent-powered assembly line",
  "lanes": [
    { "id": "customer",   "label": "Customer",    "color": "#1e3a5f", "height": 110 },
    { "id": "ops",        "label": "Operations",  "color": "#1a3a2a", "height": 130 },
    { "id": "warehouse",  "label": "Warehouse",   "color": "#2a1a3a", "height": 130 },
    { "id": "production", "label": "Production",  "color": "#1a2010", "height": 130 }
  ],
  "metrics": [
    { "id": "m1", "label": "Lead Time",   "before": "3-4 weeks", "after": "3-5 days",  "change": "-85%",  "positive": true  },
    { "id": "m2", "label": "Rework Rate", "before": "40%",       "after": "4%",        "change": "-90%",  "positive": true  },
    { "id": "m3", "label": "Automation",  "before": "0%",        "after": "90%",       "change": "+90%",  "positive": true  },
    { "id": "m4", "label": "Throughput",  "before": "50/month",  "after": "300/month", "change": "+500%", "positive": true  }
  ],
  "nodes": [
    { "id": "b-start",    "type": "start-event",       "label": "Order\nReceived",             "lane": "customer",   "x": 110,  "phase": "before" },
    { "id": "b-intake",   "type": "task",              "label": "Phone / Email\nOrder Entry",  "lane": "ops",        "x": 250,  "phase": "before", "diff": "removed" },
